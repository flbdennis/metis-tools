---
const { title, description, icon, href } = Astro.props;
---

<a
  href={href}
  class="block bg-white rounded-xl p-3 sm:p-4 border border-gray-100 transition-all hover:-translate-y-1 hover:shadow-xl"
>
  <div class="text-2xl sm:text-3xl mb-2">{icon}</div>
  <h3 class="text-base sm:text-lg font-semibold mb-1 line-clamp-1">{title}</h3>
  <p class="text-gray-500 text-xs sm:text-sm mb-2 line-clamp-2">{description}</p>
  <span class="text-indigo-600 text-xs sm:text-sm font-medium">Try now →</span>
</a>