---
const { title, description, icon, href } = Astro.props;
---

<a
  href={href}
  class="block bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm transition-all duration-300 overflow-hidden h-full group hover:-translate-y-1 hover:shadow-lg hover:border-indigo-200 dark:hover:border-indigo-700"
>
  <div class="p-3 sm:p-4">
    <div class="text-2xl sm:text-3xl mb-1 sm:mb-2">{icon}</div>
    <h3 class="text-sm sm:text-lg font-semibold mb-1 sm:mb-2 line-clamp-1 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{title}</h3>
    <p class="text-gray-500 dark:text-gray-400 text-xs sm:text-sm mb-1 sm:mb-2 line-clamp-2">{description}</p>
    <!-- 移除了 "Try now →" -->
  </div>
</a>