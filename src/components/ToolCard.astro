---
const { title, description, icon, href } = Astro.props;
---

<a href={href} class="block bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden h-full">
  <div class="p-5">
    <div class="text-3xl mb-2">{icon}</div>
    <h3 class="text-xl font-semibold mb-2 text-gray-800 dark:text-gray-100">{title}</h3>
    <p class="text-gray-500 dark:text-gray-400 text-sm mb-4">{description}</p>
    <span class="text-indigo-600 dark:text-indigo-400 text-sm font-medium">Try now →</span>
  </div>
</a>