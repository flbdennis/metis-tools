---
const { currentPath = "/" } = Astro.props;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/converters", label: "Converters" },
  { href: "/calculators", label: "Calculators" },
  { href: "/image-tools", label: "Image Tools" },
  { href: "/text-tools", label: "Text Tools" },
  { href: "/dev-tools", label: "Dev Tools" },
  { href: "/blog", label: "Blog" },
];
function isActive(href) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700"
>
  <div class="flex items-center justify-between h-16 px-4 sm:px-6 lg:px-8">
    <a
      href="/"
      class="text-xl md:text-2xl font-bold bg-gradient-to-r from-indigo-600 to-cyan-500 bg-clip-text text-transparent flex-shrink-0"
      >MetisTools</a
    >
    <nav class="hidden md:flex items-center space-x-8">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`text-sm md:text-base text-gray-700 dark:text-gray-200 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition ${isActive(item.href) ? "text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400 pb-1" : ""}`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center space-x-2">
      <!-- <ThemeToggle /> -->
      <button
        id="menu-btn"
        class="md:hidden text-gray-700 dark:text-gray-200 text-2xl focus:outline-none p-2"
        aria-label="Toggle menu">☰</button
      >
    </div>
  </div>
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 shadow-lg"
  >
    <div class="flex flex-col py-2 px-4 sm:px-6 lg:px-8">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`block px-4 py-3 text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition ${isActive(item.href) ? "text-indigo-600 dark:text-indigo-400 bg-gray-50 dark:bg-gray-800 border-l-4 border-indigo-600 dark:border-indigo-400 pl-3" : ""}`}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
  <script>
    const menuBtn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        mobileMenu.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        if (!mobileMenu.contains(e.target) && e.target !== menuBtn) {
          mobileMenu.classList.add("hidden");
        }
      });
    }
  </script>
</header>
