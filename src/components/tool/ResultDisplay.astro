---
// 结果展示组件 —— 空状态 / 结果内容 + 复制下载按钮
// hasResult 控制初始可见状态，运行时通过 #result-empty / #result-data 的 hidden 类切换
export interface Props {
  hasResult?: boolean;
  emptyMessage?: string;
  onCopy?: boolean;
  onDownload?: boolean;
}

const {
  hasResult = false,
  emptyMessage = 'Enter values and click Calculate to see results.',
  onCopy = false,
  onDownload = false,
} = Astro.props;
---

<div class="flex-1 flex flex-col">
  <div id="result-empty" class="flex-1 flex items-center justify-center rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 p-8 text-center min-h-[200px]" class:list={[{ hidden: hasResult }]}>
    <p class="text-[15px] text-gray-400 leading-relaxed max-w-[280px]" set:html={emptyMessage}></p>
  </div>

  <div id="result-data" class="flex-1 flex flex-col" class:list={[{ hidden: !hasResult }]}>
    <div class="flex-1">
      <slot name="result-content" />
    </div>
    {(onCopy || onDownload) && (
      <div class="flex gap-2 mt-4 pt-4 border-t border-gray-100">
        {onCopy && (
          <button type="button" id="btn-copy-result" class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-lg border border-primary-200 bg-primary-50 px-3 py-2 text-sm font-medium text-primary-700 hover:bg-primary-100 transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
            Copy
          </button>
        )}
        {onDownload && (
          <button type="button" id="btn-download-result" class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-lg border border-primary-200 bg-primary-50 px-3 py-2 text-sm font-medium text-primary-700 hover:bg-primary-100 transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            Download
          </button>
        )}
      </div>
    )}
  </div>
</div>
