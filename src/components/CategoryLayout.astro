---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from './ToolCard.astro';
const { title, description, currentPath, tools } = Astro.props;
---

<BaseLayout title={title} description={description} currentPath={currentPath}>
  <section class="py-8">
    <h1 class="text-3xl font-bold mb-4 text-gray-800 dark:text-gray-100">{title}</h1>
    <p class="text-gray-600 dark:text-gray-300 mb-8">{description}</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4 md:gap-6">
      {tools.map(tool => <ToolCard {...tool} />)}
    </div>
  </section>
</BaseLayout>