---
// 顶部导航组件 —— 固定顶部，含分类下拉菜单
import { siteConfig } from '../../data/site';
import { navigationConfig } from '../../data/navigation';

const { currentPath = '/' } = Astro.props;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-200 shadow-sm">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label={siteConfig.name}>
        <img src="/logo.webp" alt={siteConfig.name} class="h-8 w-8" width="32" height="32" fetchpriority="high" />
        <span class="text-lg font-bold text-gray-900">{siteConfig.name}</span>
      </a>

      <!-- 桌面端导航 -->
      <div class="hidden lg:flex lg:items-center lg:gap-1">
        <a href="/" class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${currentPath === '/' ? 'bg-primary-50 text-primary-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}>
          Home
        </a>

        <!-- 分类下拉菜单 -->
        {navigationConfig.mainNav.filter(item => item.href !== '/' && item.href !== '/blog').map(item => (
          <a href={item.href} class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${currentPath.startsWith(item.href) ? 'bg-primary-50 text-primary-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}>
            {item.label}
          </a>
        ))}

        <span class="mx-1 h-6 w-px bg-gray-200" aria-hidden="true"></span>

        <a href="/blog" class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${currentPath.startsWith('/blog') ? 'bg-primary-50 text-primary-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'}`}>
          Blog
        </a>

        <!-- 辅助链接 -->
        {navigationConfig.secondaryNav.map(item => (
          <a href={item.href} class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${currentPath === item.href ? 'bg-primary-50 text-primary-700' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50'}`}>
            {item.label}
          </a>
        ))}
      </div>

      <!-- 移动端汉堡按钮 -->
      <button id="mobile-menu-btn" type="button" class="lg:hidden rounded-lg p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-700" aria-label="Open menu" aria-expanded="false">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- 移动端菜单（Flowbite Drawer 风格，默认隐藏） -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-200 bg-white" role="menu">
    <div class="space-y-1 px-4 py-3">
      <a href="/" class="block rounded-lg px-3 py-2.5 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-900" role="menuitem">Home</a>
      {navigationConfig.mainNav.filter(item => item.href !== '/').map(item => (
        <a href={item.href} class="block rounded-lg px-3 py-2.5 text-base font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-900" role="menuitem">
          {item.label}
        </a>
      ))}
      <hr class="my-2 border-gray-100" />
      {navigationConfig.secondaryNav.map(item => (
        <a href={item.href} class="block rounded-lg px-3 py-2.5 text-sm text-gray-500 hover:bg-gray-50 hover:text-gray-700" role="menuitem">{item.label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  // 移动端菜单切换（纯 JS，无需 Flowbite JS）
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (menuBtn && menu) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
