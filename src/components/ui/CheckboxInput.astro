---
// 自定义复选框 —— 带标签，支持 indeterminate 状态
export interface Props {
  id: string;
  label: string;
  checked?: boolean;
  disabled?: boolean;
  class?: string;
}

const {
  id,
  label,
  checked = false,
  disabled = false,
  class: extraClass = '',
} = Astro.props;
---

<label for={id} class={`checkbox-group ${extraClass}`}>
  <input
    type="checkbox"
    id={id}
    name={id}
    checked={checked}
    disabled={disabled}
    class="checkbox-input peer"
  />
  <span class="checkbox-custom"></span>
  <span class="checkbox-label">{label}</span>
</label>

<style>
  .checkbox-group {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: #374151;
    user-select: none;
  }
  .checkbox-group:has(input:disabled) {
    cursor: not-allowed;
    opacity: 0.5;
  }
  .checkbox-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .checkbox-custom {
    width: 1.15rem;
    height: 1.15rem;
    flex-shrink: 0;
    border: 1.5px solid #d1d5db;
    border-radius: 0.25rem;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s, background 0.15s;
  }
  .checkbox-input:focus-visible + .checkbox-custom {
    border-color: #4f46e5;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.15);
  }
  .checkbox-custom::after {
    content: '';
    display: block;
    width: 0.35rem;
    height: 0.6rem;
    border: solid transparent;
    border-width: 0 1.5px 1.5px 0;
    transform: rotate(45deg);
    margin-top: -1px;
  }
  .checkbox-input:checked + .checkbox-custom {
    background: #4f46e5;
    border-color: #4f46e5;
  }
  .checkbox-input:checked + .checkbox-custom::after {
    border-color: #fff;
  }
  .checkbox-label {
    line-height: 1.4;
  }
  .checkbox-group:hover .checkbox-custom {
    border-color: #4f46e5;
  }
</style>
