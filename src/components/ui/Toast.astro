---
// 自定义 Toast 通知组件 —— 替代浏览器 alert()
// 通过全局 showToast() 函数调用
---

<div id="toast-container" class="toast-container" aria-live="polite"></div>

<style is:global>
  .toast-container {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    pointer-events: none;
  }
  .toast-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: 0.5rem;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.15), 0 8px 10px -6px rgba(0,0,0,0.08);
    pointer-events: auto;
    animation: toastSlideIn 0.3s ease-out;
    min-width: 320px;
    max-width: 480px;
    font-size: 0.875rem;
    line-height: 1.4;
    border: 1px solid;
  }
  .toast-item.toast-error {
    background: #fef2f2;
    border-color: #fecaca;
    color: #991b1b;
  }
  .toast-item.toast-success {
    background: #f0fdf4;
    border-color: #bbf7d0;
    color: #166534;
  }
  .toast-item.toast-warning {
    background: #fffbeb;
    border-color: #fde68a;
    color: #92400e;
  }
  .toast-icon {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    align-self: flex-start;
    margin-top: 0.125rem;
  }
  .toast-msg {
    flex: 1;
  }
  .toast-close {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    opacity: 0.5;
    padding: 0;
    line-height: 1;
  }
  .toast-close:hover { opacity: 0.8; }
  @keyframes toastSlideIn {
    from { opacity: 0; transform: translateY(1rem); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes toastSlideOut {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(1rem); }
  }
</style>

<script>
  function showToast(message, type = 'error', duration = 4000) {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const icons = {
      error: '<svg class="toast-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
      success: '<svg class="toast-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
      warning: '<svg class="toast-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>',
    };

    const item = document.createElement('div');
    item.className = 'toast-item toast-' + type;
    item.innerHTML = icons[type] + '<span class="toast-msg">' + message + '</span><button class="toast-close" aria-label="Close">&times;</button>';

    item.querySelector('.toast-close').addEventListener('click', () => {
      item.style.animation = 'toastSlideOut 0.2s ease-in forwards';
      setTimeout(() => item.remove(), 200);
    });

    container.appendChild(item);

    if (duration > 0) {
      setTimeout(() => {
        if (item.parentNode) {
          item.style.animation = 'toastSlideOut 0.2s ease-in forwards';
          setTimeout(() => { if (item.parentNode) item.remove(); }, 200);
        }
      }, duration);
    }

    // 最多显示 4 个
    const items = container.querySelectorAll('.toast-item');
    if (items.length > 4) items[0].remove();
  }

  window.showToast = showToast;
</script>
