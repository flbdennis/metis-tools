---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

const title = "File Converters - Free Online Conversion Tools";
const description = "Convert PDF, images, videos, audio files online. Free, fast, and secure.";
const converters = [
  { title: 'PDF to Word', description: 'Convert PDF to editable DOCX', icon: '📄', href: '/tools/pdf-to-word' },
  { title: 'Image Compressor', description: 'Reduce JPG/PNG size', icon: '🖼️', href: '/tools/image-compressor' },
  { title: 'MP4 to GIF', description: 'Convert video to animated GIF', icon: '🎬', href: '/tools/mp4-to-gif' },
  { title: 'Unit Converter', description: 'Length, weight, temperature', icon: '📏', href: '/tools/unit-converter' },
  { title: 'Currency Converter', description: 'Real-time exchange rates', icon: '💱', href: '/tools/currency-converter' },
];
---

<BaseLayout title={title} description={description} currentPath="/converters">
  <section class="py-8">
    <h1 class="text-3xl font-bold mb-4">File Converters</h1>
    <p class="text-gray-600 mb-8">Convert your files to any format — completely free.</p>
<div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4 md:gap-6" id="toolsGrid">
      {converters.map(tool => <ToolCard {...tool} />)}
    </div>
  </section>
</BaseLayout>