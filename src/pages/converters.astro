---
import CategoryLayout from '../components/CategoryLayout.astro';
import { allTools } from '../data/tools';

const title = "File Converters - Free Online Conversion Tools";
const description = "Convert PDF, images, videos, audio files online. Free, fast, and secure.";
const converters = allTools.filter(tool => tool.category === "converters");
---

<CategoryLayout title={title} description={description} currentPath="/converters" tools={converters} />