---
import CategoryLayout from '../components/CategoryLayout.astro';
import { allTools } from '../data/tools';

const title = "Developer Tools - Online Utilities for Coders";
const description = "Free online tools for developers: timestamp converter, JSON formatter, JWT decoder, UUID generator, color converter, code beautifier.";
const devTools = allTools.filter(tool => tool.category === "dev");
---

<CategoryLayout title={title} description={description} currentPath="/dev-tools" tools={devTools} />