---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/seo/Schema.astro';
import TextInput from '../../components/ui/TextInput.astro';
import TextareaInput from '../../components/ui/TextareaInput.astro';
import { seoData } from '../../data/seo';
import { siteConfig } from '../../data/site';

const { title, description } = seoData.support.contact;
---

<BaseLayout title={title} description={description} currentPath="/support/contact">
  <div class="max-w-2xl mx-auto px-4 py-12 sm:py-16">
    <div class="rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-10 sm:p-12">
        <div class="text-center">
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900">Contact Us</h1>
          <p class="mt-3 text-gray-500">We'd love to hear from you</p>
        </div>

        <div class="mt-8 space-y-6">
          <div>
            <h2 class="text-xl font-semibold text-gray-800 text-center">Send a Message</h2>
            <form action="/api/contact" method="POST" class="mt-4 space-y-3">
              <TextInput id="contact-name" label="Name" type="text" required />
              <TextInput id="contact-email" label="Email" type="email" required />
              <TextareaInput id="contact-message" label="Message" rows={4} required />
              <button type="submit" class="tool-btn-primary w-full">Send Message</button>
            </form>
            <p class="text-xs text-gray-500 text-center mt-2">* This form is a placeholder. In production, it will send an email to the site owner.</p>
          </div>

          <div class="bg-gray-50 rounded-xl p-6 text-center">
            <p class="text-gray-700 font-medium">Email (Direct)</p>
            <a href={`mailto:${siteConfig.email}`} class="text-indigo-600 hover:underline text-lg break-all">{siteConfig.email}</a>
            <p class="text-sm text-gray-500 mt-3">{siteConfig.contact.responseTime} response time.</p>
          </div>
        </div>

        <div class="mt-10">
          <h2 class="text-xl font-semibold text-gray-800 text-center">What to Include</h2>
          <ul class="mt-4 list-disc list-inside text-gray-600 space-y-1 text-center">
            <li>Tool suggestions</li>
            <li>Bug reports (please include browser version and steps)</li>
            <li>General feedback</li>
            <li><strong>Business inquiries</strong> (advertising, partnerships)</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
  <Schema type="WebSite" />
</BaseLayout>
