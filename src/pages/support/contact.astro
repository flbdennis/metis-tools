---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';

const title = "Contact MetisTools – Get in Touch";
const description = "Contact MetisTools for feedback, bug reports, or tool suggestions. We respond within 2-3 business days.";
---

<BaseLayout title={title} description={description} currentPath="/support/contact">
  <div class="max-w-2xl mx-auto px-4 py-12 sm:py-16">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-10 sm:p-12 text-center">
        <div class="text-5xl mb-4">📬</div>
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900">Contact Us</h1>
        <p class="mt-3 text-gray-500">We'd love to hear from you</p>

        <div class="mt-8 max-w-sm mx-auto">
          <div class="bg-gray-50 rounded-xl p-6">
            <div class="text-4xl mb-2">📧</div>
            <p class="text-gray-700 font-medium">Email</p>
            <a href="mailto:flbdennis.fan@gmail.com" class="text-indigo-600 hover:underline text-lg break-all">flbdennis.fan@gmail.com</a>
            <p class="text-sm text-gray-500 mt-3">We aim to respond within 2-3 business days.</p>
          </div>
        </div>

        <div class="mt-10">
          <h2 class="text-xl font-semibold text-gray-800">💡 What to Include</h2>
          <ul class="mt-4 list-disc list-inside text-gray-600 space-y-1">
            <li>Tool suggestions</li>
            <li>Bug reports (please include browser version and steps)</li>
            <li>General feedback</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
  <Schema
    toolName="Contact Page"
    description={description}
    url="https://metis-tools.pages.dev/support/contact"
  />
</BaseLayout>