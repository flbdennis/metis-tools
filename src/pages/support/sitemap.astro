---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { allTools } from '../../data/tools';

const toolPages = allTools.map(tool => ({ name: tool.title, url: tool.href }));
const otherPages = [
  { name: 'Home', url: '/' },
  { name: 'Calculators', url: '/calculators' },
  { name: 'Converters', url: '/converters' },
  { name: 'Image Tools', url: '/image-tools' },
  { name: 'Text Tools', url: '/text-tools' },
  { name: 'Developer Tools', url: '/dev-tools' },
  { name: 'Blog', url: '/blog' },
  { name: 'About', url: '/support/about' },
  { name: 'Contact', url: '/support/contact' },
  { name: 'FAQ', url: '/support/faq' },
  { name: 'Privacy Policy', url: '/support/privacy-policy' },
  { name: 'Terms of Service', url: '/support/terms' },
];

const title = 'Sitemap – All MetisTools Pages';
const description = 'Complete sitemap of MetisTools: all converters, calculators, developer tools, image tools, text utilities, and information pages.';
---

<BaseLayout title={title} description={description} currentPath="/support/sitemap">
  <div class="max-w-4xl mx-auto px-4 py-12 sm:py-16">
    <div class="rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-10 sm:p-12">
        <div class="text-center">
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900">Sitemap</h1>
          <p class="mt-3 text-gray-500">All pages and tools on MetisTools</p>
        </div>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Information Pages</h2>
            <ul class="space-y-2">
              {otherPages.map(page => (
                <li><a href={page.url} class="text-indigo-600 hover:underline">{page.name}</a></li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4">All Tools</h2>
            <ul class="space-y-1 columns-2 gap-4">
              {toolPages.map(tool => (
                <li><a href={tool.url} class="text-indigo-600 hover:underline text-sm">{tool.name}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
