---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';

const title = "About MetisTools – Free Online Toolbox";
const description = "MetisTools provides free, private, all-in-one online converters, calculators, and developer tools. No signup required.";
---

<BaseLayout title={title} description={description} currentPath="/support/about">
  <div class="max-w-3xl mx-auto px-4 py-12 sm:py-16">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-10 sm:p-12">
        <div class="text-center">
          <div class="text-5xl mb-4">🛠️</div>
          <h1 class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-indigo-600 to-indigo-500 bg-clip-text text-transparent">About MetisTools</h1>
          <p class="mt-3 text-lg text-gray-500">Your trusted source for free online tools</p>
        </div>

        <div class="mt-10 space-y-8">
          <div class="flex gap-4">
            <div class="flex-shrink-0 text-2xl">🎯</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800">Our Mission</h2>
              <p class="mt-1 text-gray-600 leading-relaxed">We believe essential tools should be accessible to everyone, everywhere. No paywalls, no data collection, no distractions – just pure functionality that works.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 text-2xl">🛠️</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800">What We Offer</h2>
              <p class="mt-1 text-gray-600 leading-relaxed">From unit converters and calculators to PDF tools, image editors, and developer utilities – all running locally in your browser. Your files never leave your device.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 text-2xl">🚀</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800">Our Vision</h2>
              <p class="mt-1 text-gray-600 leading-relaxed">To build the most comprehensive, fast, and private toolkit on the web. Every tool is designed with simplicity and performance in mind.</p>
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-6 flex gap-4">
            <div class="flex-shrink-0 text-2xl">💬</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800">Get in Touch</h2>
              <p class="mt-1 text-gray-600">Have feedback or suggestions? We'd love to hear from you.</p>
              <p class="mt-3">
                <a href="/support/contact" class="inline-flex items-center text-indigo-600 hover:text-indigo-800 font-medium">
                  Contact us
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <Schema
    toolName="About MetisTools"
    description={description}
    url="https://metis-tools.pages.dev/support/about"
  />
</BaseLayout>