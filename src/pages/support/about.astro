---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
const siteUrl = Astro.site.href;

const title = "About MetisTools – Free Online Toolbox";
const description = "MetisTools provides free, private, all-in-one online converters, calculators, and developer tools. No signup required.";
---

<BaseLayout title={title} description={description} currentPath="/support/about">
  <div class="max-w-3xl mx-auto px-4 py-12 sm:py-16">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
      <div class="px-6 py-10 sm:p-12">
        <div class="text-center">
          <div class="text-5xl mb-4">🛠️</div>
          <h1 class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-indigo-600 to-indigo-500 bg-clip-text text-transparent">About MetisTools</h1>
          <p class="mt-3 text-lg text-gray-500 dark:text-gray-400">Your trusted source for free online tools</p>
        </div>

        <div class="mt-10 space-y-8">
          <!-- 创始人信息（增强可信度） -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 text-2xl">👤</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">Behind the Tools</h2>
              <p class="mt-1 text-gray-600 dark:text-gray-300 leading-relaxed">
                MetisTools is proudly developed by <strong>Dennis Fan</strong>, a full-stack developer with over 5 years of experience in web performance and security. Frustrated by slow, ad‑ridden tool sites, Dennis built this platform from the ground up to be fast, private, and completely free.
              </p>
              <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">
                Every tool runs locally in your browser – no data is ever uploaded to our servers. Your privacy is our priority.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 text-2xl">🎯</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">Our Mission</h2>
              <p class="mt-1 text-gray-600 dark:text-gray-300 leading-relaxed">We believe essential tools should be accessible to everyone, everywhere. No paywalls, no data collection, no distractions – just pure functionality that works.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 text-2xl">🛠️</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">What We Offer</h2>
              <p class="mt-1 text-gray-600 dark:text-gray-300 leading-relaxed">From unit converters and calculators to PDF tools, image editors, and developer utilities – all running locally in your browser. Your files never leave your device.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 text-2xl">🚀</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">Our Vision</h2>
              <p class="mt-1 text-gray-600 dark:text-gray-300 leading-relaxed">To build the most comprehensive, fast, and private toolkit on the web. Every tool is designed with simplicity and performance in mind.</p>
            </div>
          </div>

          <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-6 flex gap-4">
            <div class="flex-shrink-0 text-2xl">💬</div>
            <div>
              <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">Get in Touch</h2>
              <p class="mt-1 text-gray-600 dark:text-gray-300">Have feedback or suggestions? We'd love to hear from you.</p>
              <p class="mt-3">
                <a href="/support/contact" class="inline-flex items-center text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 font-medium">
                  Contact us
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <Schema
    toolName="About MetisTools"
    description={description}
    url={siteUrl + "/support/about"}
  />
</BaseLayout>