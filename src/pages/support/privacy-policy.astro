---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
const siteUrl = Astro.site.href;
const title = "Privacy Policy – MetisTools";
const description = "MetisTools privacy policy: we respect your privacy. No personal data stored, anonymous analytics only.";
---

<BaseLayout title={title} description={description} currentPath="/support/privacy-policy">
  <div class="max-w-3xl mx-auto px-4 py-12 sm:py-16">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-10 sm:p-12">
        <div class="text-center">
          <div class="text-5xl mb-4">🔒</div>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900">Privacy Policy</h1>
          <p class="mt-3 text-gray-500">Last updated: May 15, 2026</p>
        </div>

        <div class="mt-10 space-y-6 divide-y divide-gray-100">
          <div class="pt-0">
            <h2 class="text-xl font-semibold text-gray-800">1. Information We Collect</h2>
            <p class="mt-2 text-gray-600 leading-relaxed">We do not require registration. We collect only anonymized usage data via Google Analytics (e.g., page views, tool interactions). No personal information is stored on our servers.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800">2. Cookies</h2>
            <p class="mt-2 text-gray-600 leading-relaxed">We use essential cookies for functionality and analytics cookies (Google Analytics). You can block cookies via browser settings, but some features may degrade.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800">3. Third‑Party Services</h2>
            <ul class="mt-2 list-disc list-inside text-gray-600 space-y-1">
              <li><strong>Google Analytics</strong> – collects anonymous traffic data. <a href="https://policies.google.com/privacy" class="text-indigo-600 hover:underline">Google Privacy Policy</a>.</li>
              <li><strong>Cloudflare Pages</strong> – hosts the website, may log IP addresses for security.</li>
            </ul>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800">4. Data Sharing</h2>
            <p class="mt-2 text-gray-600 leading-relaxed">We never sell or share your personal data with third parties.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800">5. Contact</h2>
            <p class="mt-2 text-gray-600">If you have any questions, please contact us at:</p>
            <p class="mt-1 font-mono text-indigo-600">flbdennis.fan@gmail.com</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <Schema
    toolName="Privacy Policy"
    description={description}
    url={siteUrl + "/support/privacy-policy"}
  />
</BaseLayout>