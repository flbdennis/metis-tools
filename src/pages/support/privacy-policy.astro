---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
const siteUrl = Astro.site.href;
const title = "Privacy Policy – MetisTools";
const description = "Privacy policy for MetisTools: how we use Google Analytics, AdSense, cookies, and your data rights.";
---

<BaseLayout title={title} description={description} currentPath="/support/privacy-policy">
  <div class="max-w-3xl mx-auto px-4 py-12 sm:py-16">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
      <div class="px-6 py-10 sm:p-12">
        <div class="text-center">
          <div class="text-5xl mb-4">🔒</div>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100">Privacy Policy</h1>
          <p class="mt-3 text-gray-500 dark:text-gray-400">Last updated: May 16, 2026</p>
        </div>

        <div class="mt-10 space-y-6 divide-y divide-gray-100 dark:divide-gray-700">
          <div>
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">1. Information We Collect</h2>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">We do not require registration. We collect only anonymized usage data via Google Analytics (e.g., page views, tool interactions). No personal information is stored on our servers.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">2. Cookies & Tracking</h2>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">We use essential cookies for functionality and analytics cookies (Google Analytics). We also use cookies for advertising through Google AdSense. By using our site, you consent to the use of cookies. You can manage cookie preferences through your browser settings.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">3. Google AdSense</h2>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">We use Google AdSense to serve ads. Google may use cookies to serve ads based on your prior visits to our site or other websites. You may opt out of personalized advertising by visiting <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">Google Ad Settings</a>.</p>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">Third-party vendors, including Google, use cookies to serve ads based on a user's prior visits to this website or other websites.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">4. Third‑Party Services</h2>
            <ul class="mt-2 list-disc list-inside text-gray-600 dark:text-gray-300 space-y-1">
              <li><strong>Google Analytics</strong> – collects anonymous traffic data. <a href="https://policies.google.com/privacy" class="text-indigo-600 hover:underline">Google Privacy Policy</a>.</li>
              <li><strong>Cloudflare Pages</strong> – hosts the website, may log IP addresses for security.</li>
              <li><strong>Google AdSense</strong> – serves advertisements. <a href="https://policies.google.com/technologies/ads" class="text-indigo-600 hover:underline">Google Ad Policies</a>.</li>
            </ul>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">5. Data Sharing & Security</h2>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">We never sell or share your personal data with third parties. We implement reasonable security measures to protect any data we collect.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">6. Children's Privacy</h2>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">Our site is not intended for children under 13. We do not knowingly collect personal information from children under 13.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">7. Your Choices</h2>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">You can disable cookies in your browser settings. You can also opt out of personalized ads via the <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">Google Ads Settings</a> page. For Google Analytics, you can install the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">Google Analytics Opt-out Browser Add-on</a>.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">8. Changes to This Policy</h2>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">We may update this privacy policy from time to time. Any changes will be posted on this page with an updated revision date.</p>
          </div>

          <div class="pt-6">
            <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">9. Contact Us</h2>
            <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">If you have any questions about this privacy policy, please contact us at:</p>
            <p class="mt-1 font-mono text-indigo-600 dark:text-indigo-400">flbdennis.fan@gmail.com</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <Schema
    toolName="Privacy Policy"
    description={description}
    url={siteUrl + "/support/privacy-policy"}
  />
</BaseLayout>