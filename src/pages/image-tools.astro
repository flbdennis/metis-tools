---
import CategoryLayout from '../components/CategoryLayout.astro';
import { allTools } from '../data/tools';

const title = "Image Tools - Free Online Image Processing";
const description = "Compress, convert, crop, resize images online. All processing done locally in your browser.";
const imageTools = allTools.filter(tool => tool.category === "image");
---

<CategoryLayout title={title} description={description} currentPath="/image-tools" tools={imageTools} />