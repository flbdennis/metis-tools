---
import CategoryLayout from '../components/CategoryLayout.astro';
import { allTools } from '../data/tools';

const title = "Text Tools - Free Online Text Processing Utilities";
const description = "Case converter, encoding/decoding, regex tester, duplicate remover, sorting, statistics, and more. All in your browser.";
const textTools = allTools.filter(tool => tool.category === "text");
---

<CategoryLayout title={title} description={description} currentPath="/text-tools" tools={textTools} />