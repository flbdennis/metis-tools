---
import CategoryLayout from '../components/CategoryLayout.astro';
import { allTools } from '../data/tools';

const title = "Online Calculators - Free Math & Health Tools";
const description = "BMI, Age, Tip, Mortgage, Date difference, and more. All calculators free to use.";
const calculators = allTools.filter(tool => tool.category === "calculators");
---

<CategoryLayout title={title} description={description} currentPath="/calculators" tools={calculators} />