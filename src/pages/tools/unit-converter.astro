---
// 单位转换器页面 —— 12 类单位双向转换
import ToolLayout from '../../layouts/ToolLayout.astro';
import NumberInput from '../../components/ui/NumberInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Unit Converter — Free Online Unit Conversion Tool';
const pageDescription = 'Convert between metric and imperial units across 12 categories including length, weight, temperature, volume, speed, area, and more.';

const categoryOptions = [
  { value: 'length', label: 'Length' },
  { value: 'weight', label: 'Weight' },
  { value: 'temperature', label: 'Temperature' },
  { value: 'volume', label: 'Volume' },
  { value: 'speed', label: 'Speed' },
  { value: 'area', label: 'Area' },
  { value: 'data', label: 'Data Storage' },
  { value: 'time', label: 'Time' },
  { value: 'pressure', label: 'Pressure' },
  { value: 'energy', label: 'Energy' },
  { value: 'power', label: 'Power' },
  { value: 'angle', label: 'Angle' },
];

const unitMap = {
  length: [
    { value: 'meter', label: 'Meter (m)' }, { value: 'kilometer', label: 'Kilometer (km)' },
    { value: 'centimeter', label: 'Centimeter (cm)' }, { value: 'millimeter', label: 'Millimeter (mm)' },
    { value: 'mile', label: 'Mile (mi)' }, { value: 'yard', label: 'Yard (yd)' },
    { value: 'foot', label: 'Foot (ft)' }, { value: 'inch', label: 'Inch (in)' },
  ],
  weight: [
    { value: 'kilogram', label: 'Kilogram (kg)' }, { value: 'gram', label: 'Gram (g)' },
    { value: 'milligram', label: 'Milligram (mg)' }, { value: 'pound', label: 'Pound (lb)' },
    { value: 'ounce', label: 'Ounce (oz)' }, { value: 'stone', label: 'Stone (st)' },
  ],
  temperature: [
    { value: 'celsius', label: 'Celsius (°C)' }, { value: 'fahrenheit', label: 'Fahrenheit (°F)' },
    { value: 'kelvin', label: 'Kelvin (K)' },
  ],
  volume: [
    { value: 'liter', label: 'Liter (L)' }, { value: 'milliliter', label: 'Milliliter (mL)' },
    { value: 'gallon_us', label: 'Gallon (US)' }, { value: 'gallon_uk', label: 'Gallon (UK)' },
    { value: 'quart', label: 'Quart' }, { value: 'pint', label: 'Pint' },
    { value: 'cup', label: 'Cup' }, { value: 'fluid_ounce', label: 'Fluid Ounce' },
  ],
  speed: [
    { value: 'kmh', label: 'km/h' }, { value: 'mph', label: 'mph' },
    { value: 'ms', label: 'm/s' }, { value: 'knot', label: 'Knot' },
  ],
  area: [
    { value: 'sq_meter', label: 'Square Meter (m²)' }, { value: 'sq_kilometer', label: 'Square Kilometer (km²)' },
    { value: 'sq_foot', label: 'Square Foot (ft²)' }, { value: 'sq_mile', label: 'Square Mile (mi²)' },
    { value: 'acre', label: 'Acre' }, { value: 'hectare', label: 'Hectare (ha)' },
  ],
  data: [
    { value: 'byte', label: 'Byte (B)' }, { value: 'kilobyte', label: 'Kilobyte (KB)' },
    { value: 'megabyte', label: 'Megabyte (MB)' }, { value: 'gigabyte', label: 'Gigabyte (GB)' },
    { value: 'terabyte', label: 'Terabyte (TB)' }, { value: 'bit', label: 'Bit' },
  ],
  time: [
    { value: 'second', label: 'Second (s)' }, { value: 'minute', label: 'Minute (min)' },
    { value: 'hour', label: 'Hour (h)' }, { value: 'day', label: 'Day' },
    { value: 'week', label: 'Week' }, { value: 'month', label: 'Month (30 days)' }, { value: 'year', label: 'Year (365 days)' },
  ],
  pressure: [
    { value: 'pascal', label: 'Pascal (Pa)' }, { value: 'bar', label: 'Bar' },
    { value: 'psi', label: 'PSI' }, { value: 'atm', label: 'Atmosphere (atm)' }, { value: 'mmhg', label: 'mmHg' },
  ],
  energy: [
    { value: 'joule', label: 'Joule (J)' }, { value: 'kilojoule', label: 'Kilojoule (kJ)' },
    { value: 'calorie', label: 'Calorie (cal)' }, { value: 'kcal', label: 'Kilocalorie (kcal)' },
    { value: 'watt_hour', label: 'Watt-hour (Wh)' }, { value: 'kwh', label: 'Kilowatt-hour (kWh)' },
  ],
  power: [
    { value: 'watt', label: 'Watt (W)' }, { value: 'kilowatt', label: 'Kilowatt (kW)' },
    { value: 'horsepower', label: 'Horsepower (hp)' }, { value: 'btu_per_hour', label: 'BTU/h' },
  ],
  angle: [
    { value: 'degree', label: 'Degree (°)' }, { value: 'radian', label: 'Radian (rad)' },
    { value: 'gradian', label: 'Gradian (gon)' },
  ],
};
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/unit-converter">
  <div slot="input">
    <div class="space-y-4">
      <SelectInput id="unit-category" label="Category" options={categoryOptions} selected="length" />
      <NumberInput id="input-value" label="Value" placeholder="e.g. 100" decimalPlaces={6} allowNegative={true} required={true} />
      <div class="grid grid-cols-2 gap-3">
        <div id="from-unit-wrapper">
          <label for="from-unit" class="tool-label">From</label>
          <select id="from-unit" class="tool-input"></select>
        </div>
        <div id="to-unit-wrapper">
          <label for="to-unit" class="tool-label">To</label>
          <select id="to-unit" class="tool-input"></select>
        </div>
      </div>
      <button type="button" id="convert-btn" class="tool-btn-primary w-full">Convert</button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Select a category, enter a value, then click <strong>Convert</strong> to see the result.">
      <div slot="result-content">
        <div class="text-center mb-5">
          <div class="text-sm text-gray-400" id="input-display">--</div>
          <div class="text-3xl font-bold text-primary-600 mt-1" id="result-display">--</div>
        </div>

        <div class="grid grid-cols-2 gap-2 mb-4" id="quick-conversions"></div>

        <div class="mt-auto bg-gray-50 rounded-lg p-3">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-600">Conversion factor</span>
            <span class="text-xs text-gray-400" id="formula-text">--</span>
          </div>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>Convert between hundreds of units across 12 categories. Select a category, enter a value, and pick your from/to units. All conversions are computed locally in your browser.</p>
  </div>
</ToolLayout>

<script define:vars={{ unitMapJson: JSON.stringify(unitMap) }}>
  const unitMap = JSON.parse(unitMapJson);
  const conversionToBase = {
    length: { meter: 1, kilometer: 1000, centimeter: 0.01, millimeter: 0.001, mile: 1609.344, yard: 0.9144, foot: 0.3048, inch: 0.0254 },
    weight: { kilogram: 1, gram: 0.001, milligram: 0.000001, pound: 0.45359237, ounce: 0.028349523125, stone: 6.35029318 },
    volume: { liter: 1, milliliter: 0.001, gallon_us: 3.785411784, gallon_uk: 4.54609, quart: 0.946352946, pint: 0.473176473, cup: 0.2365882365, fluid_ounce: 0.0295735295625 },
    speed: { kmh: 1, mph: 1.609344, ms: 3.6, knot: 1.852 },
    area: { sq_meter: 1, sq_kilometer: 1000000, sq_foot: 0.09290304, sq_mile: 2589988.110336, acre: 4046.8564224, hectare: 10000 },
    data: { byte: 1, kilobyte: 1024, megabyte: 1048576, gigabyte: 1073741824, terabyte: 1099511627776, bit: 0.125 },
    time: { second: 1, minute: 60, hour: 3600, day: 86400, week: 604800, month: 2592000, year: 31536000 },
    pressure: { pascal: 1, bar: 100000, psi: 6894.757293168, atm: 101325, mmhg: 133.322368421 },
    energy: { joule: 1, kilojoule: 1000, calorie: 4.184, kcal: 4184, watt_hour: 3600, kwh: 3600000 },
    power: { watt: 1, kilowatt: 1000, horsepower: 745.699871582, btu_per_hour: 0.29307107 },
    angle: { degree: 1, radian: 57.29577951308232, gradian: 0.9 },
  };

  function convertTemperature(value, from, to) {
    let c = from === 'celsius' ? value : from === 'fahrenheit' ? (value - 32) * 5 / 9 : value - 273.15;
    if (to === 'celsius') return c;
    if (to === 'fahrenheit') return c * 9 / 5 + 32;
    return c + 273.15;
  }

  window.__unitMap = unitMap;

  function populateUnitSelects(category) {
    const units = window.__unitMap[category] || [];
    ['from-unit', 'to-unit'].forEach((id, idx) => {
      const sel = document.getElementById(id);
      if (sel) sel.innerHTML = units.map((u, i) => `<option value="${u.value}" ${i === idx ? 'selected' : ''}>${u.label}</option>`).join('');
    });
  }

  function convert() {
    const category = document.getElementById('unit-category')?.value || 'length';
    const value = parseFloat(document.getElementById('input-value')?.value);
    const from = document.getElementById('from-unit')?.value;
    const to = document.getElementById('to-unit')?.value;
    if (isNaN(value)) { showToast('Please enter a valid number.', 'error'); return; }

    let result;
    if (category === 'temperature') {
      result = convertTemperature(value, from, to);
    } else {
      const factors = conversionToBase[category];
      result = (value * factors[from]) / factors[to];
    }

    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');

    const fromLabel = window.__unitMap[category]?.find(u => u.value === from)?.label || from;
    const toLabel = window.__unitMap[category]?.find(u => u.value === to)?.label || to;
    document.getElementById('input-display').textContent = value + ' ' + fromLabel;
    document.getElementById('result-display').textContent = parseFloat(result.toPrecision(10)) + ' ' + toLabel;

    const units = window.__unitMap[category] || [];
    const otherUnits = units.filter(u => u.value !== from && u.value !== to).slice(0, 4);
    document.getElementById('quick-conversions').innerHTML = otherUnits.map(u => {
      let qr = category === 'temperature' ? convertTemperature(value, from, u.value) : (value * conversionToBase[category][from]) / conversionToBase[category][u.value];
      return `<div class="bg-gray-50 rounded-lg p-2 text-center text-xs"><div class="font-semibold text-gray-800">${parseFloat(qr.toPrecision(8))}</div><div class="text-gray-400">${u.label}</div></div>`;
    }).join('');

    document.getElementById('formula-text').textContent = '1 ' + from + ' = ' + parseFloat((conversionToBase[category]?.[from] || 1) / (conversionToBase[category]?.[to] || 1)).toPrecision(10) + ' ' + to;
  }

  function initCategory() {
    const catSelect = document.getElementById('unit-category');
    if (!catSelect || catSelect.dataset._init) return;
    catSelect.dataset._init = '1';
    catSelect.addEventListener('change', () => {
      populateUnitSelects(catSelect.value);
      document.getElementById('result-data')?.classList.add('hidden');
      document.getElementById('result-empty')?.classList.remove('hidden');
    });
    document.addEventListener('select-change', (e) => {
      if (e.target?.closest('.custom-select-wrapper')?.dataset?.selectId === 'unit-category') {
        populateUnitSelects(e.detail.value);
        document.getElementById('result-data')?.classList.add('hidden');
        document.getElementById('result-empty')?.classList.remove('hidden');
      }
    });
  }

  populateUnitSelects('length');
  initCategory();
  document.addEventListener('astro:page-load', () => { populateUnitSelects('length'); initCategory(); });
  document.getElementById('convert-btn')?.addEventListener('click', convert);
</script>
