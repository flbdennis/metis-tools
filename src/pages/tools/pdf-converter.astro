---
// PDF Converter —— PDF → Image / Text / HTML
import ToolLayout from '../../layouts/ToolLayout.astro';
import FileUpload from '../../components/ui/FileUpload.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import ProgressBar from '../../components/ui/ProgressBar.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'PDF Converter – Convert PDF to Image, Text, HTML | MetisTools';
const pageDescription = 'Convert PDF files to images (PNG/JPEG), extract text, or convert to HTML. Free online PDF converter with no file size limits. No signup required.';

const formatOptions = [
  { value: 'png', label: 'Image – PNG' },
  { value: 'jpeg', label: 'Image – JPEG' },
  { value: 'text', label: 'Text' },
  { value: 'html', label: 'HTML' },
];
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/pdf-converter">
  <div slot="input">
    <div class="space-y-4">
      <FileUpload id="pdf-file" label="PDF File" accept=".pdf,application/pdf" helperText="PDF files up to 50MB" required={true} />

      <SelectInput id="pdf-format" label="Output Format" options={formatOptions} selected="png" />

      <button type="button" id="convert-pdf" class="tool-btn-primary w-full" disabled>
        Convert PDF
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Select a PDF file and output format, then click <strong>Convert PDF</strong> to start." onDownload={true}>
      <div slot="result-content" class="space-y-4">
        <ProgressBar visible={false} />

        <!-- 图片输出 -->
        <div id="pdf-result-images" class="hidden space-y-3 max-h-96 overflow-y-auto"></div>

        <!-- 文本输出 -->
        <div id="pdf-result-text" class="hidden">
          <textarea id="pdf-text-output" class="w-full h-64 rounded-lg border border-gray-300 bg-white p-3 text-sm text-gray-800 resize-y focus:border-primary-500 focus:ring-2 focus:ring-primary-200" readonly></textarea>
        </div>

        <!-- HTML 输出 -->
        <div id="pdf-result-html" class="hidden">
          <iframe id="pdf-html-preview" class="w-full h-80 rounded-lg border border-gray-300 bg-white" srcdoc="" sandbox="allow-same-origin allow-scripts"></iframe>
          <div class="flex items-center justify-between mt-3">
            <span class="text-xs text-gray-400">Preview</span>
          </div>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      Convert your PDF documents to images, text, or HTML with this free online PDF converter.
      All processing happens locally in your browser — your files are never uploaded to any server,
      ensuring complete privacy and security.
    </p>
    <ul>
      <li><strong>PDF to Image:</strong> Convert each page to high-quality PNG or JPEG images. Download individually or as a ZIP archive.</li>
      <li><strong>PDF to Text:</strong> Extract all readable text from your PDF. Great for editing, copying, or repurposing content.</li>
      <li><strong>PDF to HTML:</strong> Convert your PDF content into an HTML file you can view in any browser. The generated HTML is pure image-based, works everywhere.</li>
    </ul>
    <p>
      Supports PDF files up to 50MB. No signup, no watermarks, and no file limits. Your documents stay private
      because all conversion is done directly in your browser using client-side processing.
    </p>
  </div>
</ToolLayout>

<script>
  import { pdfToImages, pdfToText, pdfToHtml } from '../../lib/pdf-tools.js';

let currentFile = null;
let currentHtmlBlob = null;
let currentImageBlobs = null;

function clearResults() {
  currentImageBlobs = null;
  currentHtmlBlob = null;
  document.getElementById('result-data').classList.add('hidden');
  document.getElementById('result-empty').classList.remove('hidden');
  ['pdf-result-images', 'pdf-result-text', 'pdf-result-html'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('hidden');
  });
  const imgContainer = document.getElementById('pdf-result-images');
  if (imgContainer) imgContainer.innerHTML = '';
  const textarea = document.getElementById('pdf-text-output');
  if (textarea) textarea.value = '';
  const iframe = document.getElementById('pdf-html-preview');
  if (iframe) iframe.srcdoc = '';
  hideProgress();
}

document.getElementById('pdf-file')?.addEventListener('file-selected', (e) => {
  currentFile = e.detail.file;
  clearResults();
  document.getElementById('convert-pdf').disabled = false;
});

document.getElementById('pdf-file')?.addEventListener('file-cleared', () => {
  currentFile = null;
  currentImageBlobs = null;
  currentHtmlBlob = null;
  clearResults();
  document.getElementById('convert-pdf').disabled = true;
});

function showResult(sectionId) {
  ['pdf-result-images', 'pdf-result-text', 'pdf-result-html'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.add('hidden');
  });
  const target = document.getElementById(sectionId);
  if (target) target.classList.remove('hidden');
}

// 动态加载 JSZip 并打包下载
async function downloadImagesAsZip(blobs, fileName) {
  if (typeof JSZip === 'undefined') {
    await new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }
  const zip = new JSZip();
  blobs.forEach((blob, idx) => {
    zip.file(`page-${idx + 1}.png`, blob);
  });
  const content = await zip.generateAsync({ type: 'blob' });
  const url = URL.createObjectURL(content);
  const a = document.createElement('a');
  a.href = url;
  a.download = fileName.replace(/\.pdf$/i, '') + '.zip';
  a.click();
  URL.revokeObjectURL(url);
}

async function convertPdf() {
  const format = document.getElementById('pdf-format')?.value;

  if (!currentFile) { showToast('Please select a PDF file.', 'error'); return; }
  if (!format) { showToast('Please select an output format.', 'error'); return; }

  const btn = document.getElementById('convert-pdf');
  btn.disabled = true;
  btn.textContent = 'Converting...';

  // 清理旧内容并显示进度
  clearResults();
  document.getElementById('result-empty').classList.add('hidden');
  document.getElementById('result-data').classList.remove('hidden');
  updateProgress(20, 'Loading PDF...');

  const downloadBtn = document.getElementById('btn-download-result');
  if (downloadBtn) downloadBtn.classList.add('hidden');

  try {
    if (format === 'png' || format === 'jpeg') {
      updateProgress(40, 'Converting pages to images...');
      const mimeType = format === 'png' ? 'image/png' : 'image/jpeg';
      const blobs = await pdfToImages(currentFile, mimeType, 1.5);
      currentImageBlobs = blobs;

      updateProgress(90, 'Rendering preview...');

      const container = document.getElementById('pdf-result-images');
      if (!container) return;
      container.innerHTML = '';

      blobs.forEach((blob, i) => {
        const url = URL.createObjectURL(blob);
        const div = document.createElement('div');
        div.className = 'flex items-center gap-3 p-3 bg-white rounded-lg border border-gray-200';
        div.innerHTML = `
          <div class="w-16 h-16 flex-shrink-0 rounded bg-gray-100 overflow-hidden flex items-center justify-center">
            <img src="${url}" alt="Page ${i + 1}" class="w-full h-full object-contain" />
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-800">Page ${i + 1}</p>
            <p class="text-xs text-gray-500">${format.toUpperCase()} — ${(blob.size / 1024).toFixed(1)} KB</p>
          </div>
          <a href="${url}" download="page-${i + 1}.${format}" class="inline-flex items-center gap-1 rounded-lg border border-primary-200 bg-primary-50 px-3 py-1.5 text-xs font-medium text-primary-700 hover:bg-primary-100 transition-colors">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            Download
          </a>
        `;
        container.appendChild(div);
      });

      if (downloadBtn) {
        downloadBtn.classList.remove('hidden');
        downloadBtn.onclick = () => {
          downloadImagesAsZip(blobs, currentFile.name);
        };
      }
      showResult('pdf-result-images');
    } else if (format === 'text') {
      updateProgress(40, 'Extracting text...');
      const text = await pdfToText(currentFile);
      updateProgress(90, 'Rendering...');
      const textarea = document.getElementById('pdf-text-output');
      if (textarea) {
        textarea.value = text;
        textarea.style.height = Math.min(400, text.split('\n').length * 20 + 40) + 'px';
      }
      if (downloadBtn) {
        downloadBtn.classList.remove('hidden');
        downloadBtn.onclick = () => {
          const blob = new Blob([text], { type: 'text/plain' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = currentFile.name.replace(/\.pdf$/i, '') + '.txt';
          a.click();
          URL.revokeObjectURL(url);
        };
      }
      showResult('pdf-result-text');
    } else if (format === 'html') {
      updateProgress(40, 'Converting to HTML...');
      const html = await pdfToHtml(currentFile);
      updateProgress(90, 'Rendering preview...');
      const htmlBlob = new Blob([html], { type: 'text/html' });
      currentHtmlBlob = htmlBlob;

      const iframe = document.getElementById('pdf-html-preview');
      if (iframe) iframe.srcdoc = html;

      if (downloadBtn) {
        downloadBtn.classList.remove('hidden');
        downloadBtn.onclick = () => {
          const url = URL.createObjectURL(htmlBlob);
          const a = document.createElement('a');
          a.href = url;
          a.download = currentFile.name.replace(/\.pdf$/i, '') + '.html';
          a.click();
          URL.revokeObjectURL(url);
        };
      }
      showResult('pdf-result-html');
    }

    updateProgress(100, 'Done!');
    setTimeout(() => hideProgress(), 1500);
  } catch (err) {
    hideProgress();
    console.error(err);
    showToast(err.message || 'PDF conversion failed. Please try a different file.', 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Convert PDF';
  }
}

document.getElementById('convert-pdf')?.addEventListener('click', convertPdf);
</script>
