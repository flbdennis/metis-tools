---
import ToolLayout from '../../layouts/ToolLayout.astro';
import TextareaInput from '../../components/ui/TextareaInput.astro';
import CheckboxInput from '../../components/ui/CheckboxInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Remove Duplicate Lines – Text Cleaner | MetisTools';
const pageDescription = 'Remove duplicate lines, empty lines, and trim whitespace from text. Free online text cleaner with result statistics.';
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/remove-duplicates">
  <div slot="input">
    <div class="space-y-4">
      <TextareaInput id="rd-input" label="Input Text" placeholder="Paste your text with duplicate lines here...&#10;Line one&#10;Line two&#10;Line one&#10;Line three&#10;Line two" rows={8} monospace={true} required={true} />

      <div class="space-y-2">
        <CheckboxInput id="rd-case-sensitive" label="Case Sensitive (treat 'A' and 'a' as different)" checked={false} class="block" />
        <CheckboxInput id="rd-remove-empty" label="Remove Empty Lines" checked={true} class="block" />
        <CheckboxInput id="rd-trim" label="Trim Whitespace (leading & trailing)" checked={true} class="block" />
      </div>

      <button type="button" id="btn-remove" class="tool-btn-primary w-full">
        Remove Duplicate Lines
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Paste text and click <strong>Remove Duplicate Lines</strong> to clean up." onCopy={true} onDownload={true}>
      <div slot="result-content" class="space-y-4">
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div id="rd-output" class="text-sm font-mono whitespace-pre-wrap break-all text-gray-800 leading-relaxed max-h-[400px] overflow-y-auto"></div>
        </div>

        <div class="flex gap-4 text-xs text-gray-400 pt-3 border-t border-gray-100">
          <span>Original lines: <strong id="rd-orig-lines">0</strong></span>
          <span>Removed: <strong id="rd-removed" class="text-red-500">0</strong></span>
          <span>Remaining: <strong id="rd-remaining" class="text-emerald-600">0</strong></span>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      This free online text cleaner removes duplicate lines from any text instantly. All processing happens locally in your browser — your data is never sent to a server. Ideal for cleaning up mailing lists, log files, data exports, and more.
    </p>
    <p>
      <strong>Case Sensitive Mode:</strong> When enabled, "Apple" and "apple" are treated as different lines. When disabled (default), letter case is ignored and both are considered duplicates.
    </p>
    <p>
      <strong>Remove Empty Lines:</strong> Automatically strips blank lines and whitespace-only lines from the output, leaving only meaningful content.
    </p>
    <p>
      <strong>Trim Whitespace:</strong> Removes leading and trailing spaces/tabs from each line before comparing, so lines that differ only by indentation are still detected as duplicates.
    </p>
    <p>
      <strong>Result Statistics:</strong> See exactly how many lines were removed and how many remain, so you can verify the cleaning was effective. One-click copy or download the cleaned result.
    </p>
  </div>
</ToolLayout>

<script>
  import { removeDuplicateLines, removeEmptyLines, trimWhitespace } from '../../lib/text-tools.js';

  let currentResult = '';

  function doRemove() {
    let input = document.getElementById('rd-input')?.value || '';
    if (!input.trim()) {
      showToast('Please enter some text.', 'error');
      return;
    }

    const caseSensitive = document.getElementById('rd-case-sensitive')?.checked ?? false;
    const removeEmpty = document.getElementById('rd-remove-empty')?.checked ?? true;
    const doTrim = document.getElementById('rd-trim')?.checked ?? true;

    let processed = input;
    const origLines = processed.split(/\r?\n/).length;

    // Remove empty lines first if requested
    if (removeEmpty) {
      processed = removeEmptyLines(processed);
    }

    // Trim whitespace if requested
    if (doTrim) {
      processed = processed.split(/\r?\n/).map(l => l.trim()).join('\n');
    }

    // Remove duplicates
    const lines = processed.split(/\r?\n/);
    const seen = new Set();
    const unique = [];
    for (const line of lines) {
      const key = caseSensitive ? line : line.toLowerCase();
      if (!seen.has(key)) {
        seen.add(key);
        unique.push(line);
      }
    }
    currentResult = unique.join('\n');
    const remainingLines = unique.length;
    const removedLines = origLines - remainingLines;

    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');
    document.getElementById('rd-output').textContent = currentResult || '(no lines remaining)';
    document.getElementById('rd-orig-lines').textContent = origLines;
    document.getElementById('rd-removed').textContent = removedLines;
    document.getElementById('rd-remaining').textContent = remainingLines;
  }

  document.getElementById('btn-remove')?.addEventListener('click', doRemove);

  document.getElementById('btn-copy-result')?.addEventListener('click', () => {
    if (!currentResult) return;
    navigator.clipboard.writeText(currentResult).then(() => {
      showToast('Copied to clipboard!', 'success');
    }).catch(() => showToast('Failed to copy.', 'error'));
  });

  document.getElementById('btn-download-result')?.addEventListener('click', () => {
    if (!currentResult) return;
    const blob = new Blob([currentResult], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'deduplicated-text.txt';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
