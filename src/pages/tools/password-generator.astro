---
import ToolLayout from '../../layouts/ToolLayout.astro';
import NumberInput from '../../components/ui/NumberInput.astro';
import CheckboxInput from '../../components/ui/CheckboxInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Password Generator – Create Strong Secure Passwords | MetisTools';
const pageDescription = 'Generate strong, random passwords with customizable length and character sets. Includes strength meter, entropy display, and passphrase mode.';

const modeOptions = [
  { value: 'random', label: 'Random Password' },
  { value: 'passphrase', label: 'Passphrase (Memorable)' },
];
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/password-generator">
  <div slot="input">
    <div class="space-y-4">
      <SelectInput id="pw-mode" label="Mode" options={modeOptions} selected="random" />

      <div id="random-inputs" class="space-y-4">
        <NumberInput id="pw-length" label="Password Length" value="16" min={4} max={128} decimalPlaces={0} required={true} helperText="4 – 128 characters" />

        <div class="space-y-2">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Character Sets</p>
          <CheckboxInput id="use-upper" label="Uppercase Letters (A-Z)" checked={true} class="block" />
          <CheckboxInput id="use-lower" label="Lowercase Letters (a-z)" checked={true} class="block" />
          <CheckboxInput id="use-digits" label="Numbers (0-9)" checked={true} class="block" />
          <CheckboxInput id="use-symbols" label="Symbols (!@#$...)" checked={true} class="block" />
          <CheckboxInput id="exclude-ambiguous" label="Exclude ambiguous (i, l, 1, o, 0)" checked={false} class="block" />
        </div>
      </div>

      <div id="passphrase-inputs" class="hidden space-y-4">
        <NumberInput id="pw-word-count" label="Number of Words" value="4" min={2} max={12} decimalPlaces={0} required={true} helperText="2 – 12 words" />
        <CheckboxInput id="pp-capitalize" label="Capitalize Each Word" checked={true} class="block" />
        <CheckboxInput id="pp-add-number" label="Append Random Number" checked={true} class="block" />
        <CheckboxInput id="pp-add-symbol" label="Append Random Symbol" checked={true} class="block" />
        <SelectInput id="pp-separator" label="Word Separator" options={[{ value: '-', label: 'Hyphen (-)' }, { value: '.', label: 'Dot (.)' }, { value: '_', label: 'Underscore (_)' }, { value: ' ', label: 'Space' }]} selected="-" />
      </div>

      <div class="flex gap-2">
        <button type="button" id="btn-generate" class="tool-btn-primary flex-1">
          Generate Password
        </button>
      </div>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Choose your options and click <strong>Generate Password</strong>." onCopy={true} onDownload={true}>
      <div slot="result-content" class="space-y-4">
        <!-- 生成的密码 -->
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div id="pw-display" class="text-lg font-mono text-gray-900 break-all leading-relaxed">--</div>
        </div>

        <!-- 密码强度 -->
        <div>
          <div class="flex justify-between text-xs mb-1">
            <span class="text-gray-500">Strength</span>
            <span id="pw-strength-label" class="font-medium">--</span>
          </div>
          <div class="h-2 rounded-full bg-gray-200 overflow-hidden">
            <div id="pw-strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
          </div>
        </div>

        <!-- 熵值 -->
        <div class="flex justify-between text-sm">
          <span class="text-gray-500">Entropy</span>
          <span id="pw-entropy" class="font-mono font-medium text-gray-700">--</span>
        </div>

        <div class="flex justify-between text-sm">
          <span class="text-gray-500">Length</span>
          <span id="pw-len" class="font-mono font-medium text-gray-700">--</span>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      A strong password is your first line of defense against unauthorized access. This password generator creates truly random passwords using cryptographically secure random number generation (<code>crypto.getRandomValues</code>), ensuring every password is unique and unpredictable.
    </p>
    <p>
      <strong>Strength Meter:</strong> The color-coded bar evaluates your password based on length and character diversity — longer passwords with a mix of uppercase, lowercase, numbers, and symbols score highest.
    </p>
    <p>
      <strong>Entropy (bits):</strong> Entropy measures how unpredictable a password is. More entropy = harder to crack. A password with 60+ bits of entropy is considered strong; 80+ bits is very strong; 100+ bits is excellent.
    </p>
    <p>
      <strong>Passphrase Mode:</strong> For accounts you need to remember (like your password manager master key), use passphrase mode. It generates memorable word combinations like "Correct-Horse-Battery-Staple" with optional number and symbol suffixes.
    </p>
    <p>
      <strong>Exclude Ambiguous Characters:</strong> Removes easily confused characters (i, l, 1, o, 0) to prevent misreading when you need to type the password manually or read it aloud.
    </p>
    <p>
      <strong>Security Note:</strong> All password generation happens entirely in your browser. Passwords are never sent to any server, logged, or stored. For maximum security, use a password manager to store generated passwords.
    </p>
  </div>
</ToolLayout>

<script>
  // ---- 纯函数引用（内联以保持页面自给自足，核心逻辑在 dev-tools.js 中） ----

  const UPPER = 'ABCDEFGHJKLMNPQRSTUVWXYZ';
  const UPPER_A = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const LOWER = 'abcdefghjkmnpqrstuvwxyz';
  const LOWER_A = 'abcdefghijklmnopqrstuvwxyz';
  const DIGITS = '23456789';
  const DIGITS_A = '0123456789';
  const SYMBOLS = '!@#$%^&*()_+-=[]{}|;:,.<>?';

  function getStrength(password) {
    let s = 0;
    if (password.length >= 8) s++;
    if (password.length >= 12) s++;
    if (password.length >= 16) s++;
    if (/[A-Z]/.test(password)) s++;
    if (/[a-z]/.test(password)) s++;
    if (/[0-9]/.test(password)) s++;
    if (/[^A-Za-z0-9]/.test(password)) s++;
    if (s <= 2) return { lvl: 'Weak', clr: '#ef4444', pct: 25 };
    if (s <= 3) return { lvl: 'Fair', clr: '#f97316', pct: 45 };
    if (s <= 5) return { lvl: 'Strong', clr: '#eab308', pct: 70 };
    return { lvl: 'Very Strong', clr: '#22c55e', pct: 100 };
  }

  function calcEntropy(password, poolSize) {
    if (!password || !poolSize) return 0;
    return Math.round(password.length * Math.log2(poolSize) * 10) / 10;
  }

  function genPassword(length, upper, lower, digits, symbols, excludeAmbiguous) {
    const u = excludeAmbiguous ? UPPER : UPPER_A;
    const l = excludeAmbiguous ? LOWER : LOWER_A;
    const d = excludeAmbiguous ? DIGITS : DIGITS_A;
    let pool = '';
    const req = [];
    if (upper) { pool += u; req.push(u); }
    if (lower) { pool += l; req.push(l); }
    if (digits) { pool += d; req.push(d); }
    if (symbols) { pool += SYMBOLS; req.push(SYMBOLS); }
    if (!pool) return { password: '', entropy: 0, poolSize: 0 };

    const arr = new Uint32Array(length);
    crypto.getRandomValues(arr);
    const chars = [];
    for (let i = 0; i < req.length && i < length; i++) {
      chars.push(req[i][arr[i] % req[i].length]);
    }
    for (let i = chars.length; i < length; i++) {
      chars.push(pool[arr[i] % pool.length]);
    }
    for (let i = chars.length - 1; i > 0; i--) {
      const j = arr[arr.length - 1 - (i % (arr.length - i))] % (i + 1);
      [chars[i], chars[j]] = [chars[j], chars[i]];
    }
    const pw = chars.join('');
    return { password: pw, entropy: calcEntropy(pw, pool.length), poolSize: pool.length };
  }

  const WORDS = [
    'alpha','bravo','charlie','delta','echo','foxtrot','golf','hotel','india','juliet','kilo','lima','mike','november','oscar','papa','quebec','romeo','sierra','tango','uniform','victor','whiskey','xray','yankee','zulu',
    'apple','banana','cherry','dragon','eagle','falcon','grape','honey','iron','jade','kiwi','lemon','mango','noble','olive','pearl','quartz','ruby','silver','tiger','ultra','violet','willow','xenon','yeti','zebra',
    'amber','blaze','cloud','dusk','ember','frost','glacier','haven','ivory','jazz','karma','lotus','maple','nova','onyx','phoenix','quest','raven','storm','thorn','unity','vapor','wonder','zephyr',
    'arc','bolt','creek','dawn','echo','flame','gale','horizon','ice','knoll','lake','mist','north','oak','pine','ridge','stone','tide','vale','wave','brook','cliff','dune','fern','glen','heath','isle',
    'meadow','moor','peak','reef','shore','summit','trail','wood','bear','deer','fox','hawk','lynx','otter','puma','wolf','birch','cedar','elm','fir','holly','juniper','laurel','myrtle',
    'basil','cumin','dill','fennel','ginger','herb','mint','sage',
  ];

  function genPassphrase(wordCount, separator, addNumber, addSymbol, capitalize) {
    const arr = new Uint32Array(wordCount + 2);
    crypto.getRandomValues(arr);
    const words = [];
    for (let i = 0; i < wordCount; i++) {
      let w = WORDS[arr[i] % WORDS.length];
      if (capitalize) w = w.charAt(0).toUpperCase() + w.slice(1);
      words.push(w);
    }
    let pp = words.join(separator);
    if (addNumber) pp += arr[wordCount] % 100;
    if (addSymbol) {
      const sl = '!@#$%&*';
      pp += sl[arr[wordCount + 1] % sl.length];
    }
    return { password: pp, entropy: calcEntropy(pp, WORDS.length), poolSize: WORDS.length };
  }

  // ---- UI 逻辑 ----

  let currentPassword = '';

  function updateResult(pwObj) {
    currentPassword = pwObj.password;
    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');
    document.getElementById('pw-display').textContent = pwObj.password || '--';
    const st = getStrength(pwObj.password);
    document.getElementById('pw-strength-label').textContent = st.lvl;
    document.getElementById('pw-strength-label').style.color = st.clr;
    const bar = document.getElementById('pw-strength-bar');
    bar.style.width = st.pct + '%';
    bar.style.backgroundColor = st.clr;
    document.getElementById('pw-entropy').textContent = pwObj.entropy ? pwObj.entropy + ' bits' : '--';
    document.getElementById('pw-len').textContent = String(pwObj.password.length);
  }

  function doGenerate() {
    const mode = document.getElementById('pw-mode')?.value || 'random';
    if (mode === 'passphrase') {
      const wc = parseInt(document.getElementById('pw-word-count')?.value) || 4;
      const sep = document.getElementById('pp-separator')?.value || '-';
      const addNum = document.getElementById('pp-add-number')?.checked ?? true;
      const addSym = document.getElementById('pp-add-symbol')?.checked ?? true;
      const cap = document.getElementById('pp-capitalize')?.checked ?? true;
      updateResult(genPassphrase(wc, sep, addNum, addSym, cap));
    } else {
      const len = parseInt(document.getElementById('pw-length')?.value) || 16;
      const upper = document.getElementById('use-upper')?.checked ?? true;
      const lower = document.getElementById('use-lower')?.checked ?? true;
      const digits = document.getElementById('use-digits')?.checked ?? true;
      const symbols = document.getElementById('use-symbols')?.checked ?? true;
      const excl = document.getElementById('exclude-ambiguous')?.checked ?? false;

      if (!upper && !lower && !digits && !symbols) {
        showToast('Please select at least one character set.', 'error');
        return;
      }
      updateResult(genPassword(len, upper, lower, digits, symbols, excl));
    }
  }

  function toggleMode() {
    const mode = document.getElementById('pw-mode')?.value || 'random';
    document.getElementById('random-inputs').classList.toggle('hidden', mode !== 'random');
    document.getElementById('passphrase-inputs').classList.toggle('hidden', mode !== 'passphrase');
    // 清空结果
    document.getElementById('result-data').classList.add('hidden');
    document.getElementById('result-empty').classList.remove('hidden');
  }

  // 初始化
  document.getElementById('pw-mode')?.addEventListener('change', toggleMode);
  document.addEventListener('select-change', (e) => {
    if (e.target?.closest('.custom-select-wrapper')?.dataset?.selectId === 'pw-mode') {
      toggleMode();
    }
  });
  document.getElementById('btn-generate')?.addEventListener('click', doGenerate);

  // 复制功能
  document.getElementById('btn-copy-result')?.addEventListener('click', () => {
    if (!currentPassword) return;
    navigator.clipboard.writeText(currentPassword).then(() => {
      showToast('Password copied to clipboard!', 'success');
    }).catch(() => showToast('Failed to copy.', 'error'));
  });

  // 下载功能
  document.getElementById('btn-download-result')?.addEventListener('click', () => {
    if (!currentPassword) return;
    const blob = new Blob([currentPassword], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'password.txt';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
