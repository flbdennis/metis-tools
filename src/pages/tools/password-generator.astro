---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Random Password Generator - Secure Strong Password";
const description = "Generate strong, random passwords with custom length and character sets. Free online tool.";
---

<BaseLayout title={title} description={description} currentPath="/tools/password-generator">
  <div class="max-w-2xl mx-auto py-8">
    <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-100">
      <h1 class="text-3xl font-bold mb-2">🔐 Random Password Generator</h1>
      <p class="text-gray-600 mb-6">Create strong, secure passwords with customizable options.</p>

      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1">Password Length: <span id="length-value" class="font-mono">12</span></label>
          <input type="range" id="length" min="4" max="64" value="12" class="w-full">
        </div>
        <div class="grid grid-cols-2 gap-2">
          <label class="flex items-center"><input type="checkbox" id="uppercase" checked class="mr-2"> Uppercase (A-Z)</label>
          <label class="flex items-center"><input type="checkbox" id="lowercase" checked class="mr-2"> Lowercase (a-z)</label>
          <label class="flex items-center"><input type="checkbox" id="digits" checked class="mr-2"> Digits (0-9)</label>
          <label class="flex items-center"><input type="checkbox" id="symbols" checked class="mr-2"> Symbols (!@#$%^&*)</label>
        </div>
        <button id="generate-btn" class="w-full bg-indigo-600 text-white py-2 rounded-full">Generate Password</button>
        <div>
          <label class="block text-sm font-medium mb-1">Generated Password</label>
          <div class="flex gap-2">
            <input type="text" id="password" readonly class="flex-1 px-4 py-2 rounded-full border border-gray-300 bg-gray-50 font-mono">
            <button id="copy-btn" class="bg-gray-200 px-4 py-2 rounded-full text-sm">Copy</button>
          </div>
        </div>
        <div id="strength" class="text-sm text-center font-medium hidden"></div>
      </div>
    </div>
  </div>

  <script>
    const lengthSlider = document.getElementById('length');
    const lengthValue = document.getElementById('length-value');
    const uppercaseChk = document.getElementById('uppercase');
    const lowercaseChk = document.getElementById('lowercase');
    const digitsChk = document.getElementById('digits');
    const symbolsChk = document.getElementById('symbols');
    const generateBtn = document.getElementById('generate-btn');
    const passwordInput = document.getElementById('password');
    const copyBtn = document.getElementById('copy-btn');
    const strengthDiv = document.getElementById('strength');

    lengthSlider.addEventListener('input', () => {
      lengthValue.textContent = lengthSlider.value;
    });

    function getRandomChar(set) {
      return set[Math.floor(Math.random() * set.length)];
    }

    function generatePassword() {
      let chars = '';
      if (uppercaseChk.checked) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
      if (lowercaseChk.checked) chars += 'abcdefghijklmnopqrstuvwxyz';
      if (digitsChk.checked) chars += '0123456789';
      if (symbolsChk.checked) chars += '!@#$%^&*()_+-=[]{}|;:,.<>?';
      if (chars === '') {
        passwordInput.value = '';
        strengthDiv.classList.add('hidden');
        return;
      }
      const length = parseInt(lengthSlider.value);
      let password = '';
      for (let i = 0; i < length; i++) {
        password += getRandomChar(chars);
      }
      passwordInput.value = password;
      // 简单强度评估
      let strength = 'Weak';
      let strengthColor = 'text-red-600';
      const setsCount = [uppercaseChk.checked, lowercaseChk.checked, digitsChk.checked, symbolsChk.checked].filter(Boolean).length;
      if (length >= 12 && setsCount >= 3) strength = 'Strong';
      else if (length >= 8 && setsCount >= 2) strength = 'Medium';
      if (strength === 'Strong') strengthColor = 'text-green-600';
      else if (strength === 'Medium') strengthColor = 'text-yellow-600';
      strengthDiv.textContent = `Strength: ${strength}`;
      strengthDiv.className = `text-sm text-center font-medium ${strengthColor}`;
      strengthDiv.classList.remove('hidden');
    }

    generateBtn.addEventListener('click', generatePassword);
    copyBtn.addEventListener('click', () => {
      if (passwordInput.value) {
        navigator.clipboard.writeText(passwordInput.value).then(() => showMessage('Password copied!', 'success')).catch(() => showMessage('Failed to copy', 'error'));
      } else {
        showMessage('Generate a password first', 'error');
      }
    });
    generatePassword(); // 初始生成
  </script>
  <Schema
    toolName="Random Password Generator"
    description={description}
    url={Astro.url.href}
  />
</BaseLayout>