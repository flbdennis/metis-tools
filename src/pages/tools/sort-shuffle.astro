---
import ToolLayout from '../../layouts/ToolLayout.astro';
import TextareaInput from '../../components/ui/TextareaInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import CheckboxInput from '../../components/ui/CheckboxInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Sort & Shuffle Lines – Alphabetical, Random Order | MetisTools';
const pageDescription = 'Sort lines alphabetically (A-Z or Z-A), numerically, or randomly shuffle. Remove empty lines before sorting. Free online text sorter.';

const sortOptions = [
  { value: 'asc', label: 'A → Z (Alphabetical Ascending)' },
  { value: 'desc', label: 'Z → A (Alphabetical Descending)' },
  { value: 'numeric-asc', label: '1 → 9 (Numerical Ascending)' },
  { value: 'numeric-desc', label: '9 → 1 (Numerical Descending)' },
  { value: 'shuffle', label: 'Random Shuffle' },
];
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/sort-shuffle">
  <div slot="input">
    <div class="space-y-4">
      <TextareaInput id="ss-input" label="Input Text" placeholder="Paste your lines here...&#10;Banana&#10;Apple&#10;Cherry&#10;Date&#10;Elderberry" rows={8} monospace={true} required={true} />

      <SelectInput id="ss-order" label="Sort Order" options={sortOptions} selected="asc" />

      <CheckboxInput id="ss-remove-empty" label="Remove Empty Lines Before Sorting" checked={true} class="block" />

      <button type="button" id="btn-sort" class="tool-btn-primary w-full">
        Sort Lines
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Paste text and click <strong>Sort Lines</strong> to reorder." onCopy={true} onDownload={true}>
      <div slot="result-content" class="space-y-4">
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div id="ss-output" class="text-sm font-mono whitespace-pre-wrap break-all text-gray-800 leading-relaxed max-h-[400px] overflow-y-auto"></div>
        </div>

        <div class="flex gap-4 text-xs text-gray-400 pt-3 border-t border-gray-100">
          <span>Total lines: <strong id="ss-count">0</strong></span>
          <span>Empty removed: <strong id="ss-empty-removed">0</strong></span>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      This free online line sorter organizes your text lines in various orderings or randomly shuffles them. All processing happens locally in your browser — your data is never uploaded anywhere. Perfect for organizing lists, preparing data, or adding randomness.
    </p>
    <p>
      <strong>Alphabetical Sort (A-Z / Z-A):</strong> Sorts lines by their text content using locale-aware comparison. Useful for alphabetizing names, keywords, to-do items, and reference lists.
    </p>
    <p>
      <strong>Numerical Sort (1-9 / 9-1):</strong> Extracts the first number from each line and sorts by numeric value rather than text. Ideal for sorting version numbers, measurements, or any data with numeric prefixes.
    </p>
    <p>
      <strong>Random Shuffle:</strong> Uses the Fisher-Yates algorithm to randomly reorder lines. Great for randomizing quiz questions, assigning tasks, creating random draws, or shuffling playlists.
    </p>
    <p>
      <strong>Remove Empty Lines:</strong> When enabled, blank lines and whitespace-only lines are removed before sorting, resulting in a cleaner output. Toggle this off if you need to preserve blank lines.
    </p>
  </div>
</ToolLayout>

<script>
  import { sortLinesAlphabetically, shuffleLines } from '../../lib/text-tools.js';

  let currentResult = '';

  function doSort() {
    let input = document.getElementById('ss-input')?.value || '';
    if (!input.trim()) {
      showToast('Please enter some text.', 'error');
      return;
    }

    const order = document.getElementById('ss-order')?.value || 'asc';
    const removeEmpty = document.getElementById('ss-remove-empty')?.checked ?? true;

    let text = input;
    let emptyRemoved = 0;

    // Remove empty lines if requested
    if (removeEmpty) {
      const lines = text.split(/\r?\n/);
      const origCount = lines.length;
      text = lines.filter(l => l.trim() !== '').join('\n');
      emptyRemoved = origCount - text.split(/\r?\n/).length;
    }

    if (order === 'shuffle') {
      currentResult = shuffleLines(text);
    } else if (order.startsWith('numeric')) {
      const lines = text.split(/\r?\n/);
      lines.sort((a, b) => {
        const na = parseFloat(a.trim());
        const nb = parseFloat(b.trim());
        if (isNaN(na) && isNaN(nb)) return 0;
        if (isNaN(na)) return 1;
        if (isNaN(nb)) return -1;
        return order === 'numeric-asc' ? na - nb : nb - na;
      });
      currentResult = lines.join('\n');
    } else {
      currentResult = sortLinesAlphabetically(text, order);
    }

    const finalLines = (currentResult || '').split(/\r?\n/).length;

    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');
    document.getElementById('ss-output').textContent = currentResult || '(no lines)';
    document.getElementById('ss-count').textContent = finalLines;
    document.getElementById('ss-empty-removed').textContent = emptyRemoved;
  }

  function updateButtonLabel() {
    const order = document.getElementById('ss-order')?.value || 'asc';
    const labelMap = {
      asc: 'Sort A → Z',
      desc: 'Sort Z → A',
      'numeric-asc': 'Sort Numerically ↑',
      'numeric-desc': 'Sort Numerically ↓',
      shuffle: 'Shuffle Lines',
    };
    const btn = document.getElementById('btn-sort');
    if (btn) btn.textContent = labelMap[order] || 'Sort Lines';
  }

  document.getElementById('ss-order')?.addEventListener('change', updateButtonLabel);
  document.addEventListener('select-change', (e) => {
    if (e.target?.closest('.custom-select-wrapper')?.dataset?.selectId === 'ss-order') {
      updateButtonLabel();
    }
  });

  document.getElementById('btn-sort')?.addEventListener('click', doSort);

  document.getElementById('btn-copy-result')?.addEventListener('click', () => {
    if (!currentResult) return;
    navigator.clipboard.writeText(currentResult).then(() => {
      showToast('Copied to clipboard!', 'success');
    }).catch(() => showToast('Failed to copy.', 'error'));
  });

  document.getElementById('btn-download-result')?.addEventListener('click', () => {
    if (!currentResult) return;
    const blob = new Blob([currentResult], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'sorted-lines.txt';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
