---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPageSeo } from '../../utils/seo.js';
const { title, description } = getPageSeo('tools/mp4-to-gif'); // 根据页面修改键名
---

<BaseLayout title={title} description={description} currentPath="/tools/mp4-to-gif">
  <div class="max-w-2xl mx-auto py-8">
    <div class="bg-white dark:bg-slate-950 rounded-2xl shadow-md p-6 border border-gray-100 dark:border-slate-800">
      <h1 class="text-3xl font-bold mb-2">🎬 MP4 to GIF Converter</h1>
      <p class="text-gray-600 dark:text-gray-300 mb-6">Convert short MP4 clips into high-quality animated GIFs.</p>
      
      <div id="upload-container"></div>
      
      <div class="mt-4 grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Start time (seconds)</label>
          <input type="number" id="start-time" class="w-full px-3 py-2 rounded-full border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950" value="0" step="0.5">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Duration (seconds)</label>
          <input type="number" id="duration" class="w-full px-3 py-2 rounded-full border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950" value="5" step="0.5">
        </div>
      </div>
      
      <div id="result-area" class="mt-6 hidden">
        <div class="p-4 bg-gray-100 dark:bg-slate-900 rounded-xl text-center">
          <p class="text-green-600 font-semibold">✓ Conversion completed (simulated)</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">In production, you would get a GIF download link.</p>
          <button id="download-btn" class="mt-2 bg-indigo-600 dark:bg-indigo-500 text-white px-4 py-2 rounded-full text-sm">Download GIF</button>
        </div>
      </div>
    </div>
  </div>
  
  <script>
    function handleFile(file) {
      if (file.type !== 'video/mp4') {
        showMessage('Please upload an MP4 video file.', 'error');
        return;
      }
      showMessage('Converting MP4 to GIF... (simulated)', 'info');
      setTimeout(() => {
        document.getElementById('result-area').classList.remove('hidden');
        const downloadBtn = document.getElementById('download-btn');
        downloadBtn.addEventListener('click', () => {
          showMessage('In production, the GIF would be downloaded.', 'info');
        });
      }, 2000);
    }
    
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof initFileUpload === 'function') {
        initFileUpload('upload-container', ['video/mp4'], handleFile);
      }
    });
  </script>
  <Schema
    toolName="MP4 to GIF Converter"
    description={description}
    url={Astro.url.href}
    category="Media"
  />
</BaseLayout>