---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { textStats } from '../../lib/text-tools';

const title = "Text Statistics - Word, Character, Line Counter";
const description = "Count words, characters (with/without spaces), lines, and paragraphs in your text. Free online tool.";
---

<BaseLayout title={title} description={description} currentPath="/text-tools/text-stats">
  <div class="max-w-4xl mx-auto py-8">
    <div class="bg-white dark:bg-slate-950 rounded-2xl shadow-md p-6 border border-gray-100 dark:border-slate-800">
      <h1 class="text-3xl font-bold mb-2">📊 Text Statistics</h1>
      <p class="text-gray-600 dark:text-gray-300 mb-6">Paste your text to see word count, character count, line count, and more.</p>

      <textarea id="input-text" rows="10" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950" placeholder="Type or paste your text here..."></textarea>

      <div id="stats-area" class="mt-6 p-4 bg-gray-50 dark:bg-slate-950 rounded-xl grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div><span class="block text-2xl font-bold" id="word-count">0</span><span class="text-sm text-gray-500 dark:text-gray-400">Words</span></div>
        <div><span class="block text-2xl font-bold" id="char-count">0</span><span class="text-sm text-gray-500 dark:text-gray-400">Characters</span></div>
        <div><span class="block text-2xl font-bold" id="line-count">0</span><span class="text-sm text-gray-500 dark:text-gray-400">Lines</span></div>
        <div><span class="block text-2xl font-bold" id="char-no-space">0</span><span class="text-sm text-gray-500 dark:text-gray-400">Characters (no spaces)</span></div>
      </div>
    </div>
  </div>

  <script>
    import { textStats } from '../../lib/text-tools';

    const inputEl = document.getElementById('input-text');
    const wordSpan = document.getElementById('word-count');
    const charSpan = document.getElementById('char-count');
    const lineSpan = document.getElementById('line-count');
    const charNoSpaceSpan = document.getElementById('char-no-space');

    function updateStats() {
      const text = inputEl.value;
      const stats = textStats(text);
      wordSpan.textContent = stats.words;
      charSpan.textContent = stats.characters;
      lineSpan.textContent = stats.lines;
      // 计算不含空格的字符数（去除所有空白字符）
      const noSpace = text.replace(/\s/g, '').length;
      charNoSpaceSpan.textContent = noSpace;
    }

    inputEl.addEventListener('input', updateStats);
    updateStats(); // initial
  </script>
  <Schema
    toolName="Text Statistics"
    description={description}
    url={Astro.url.href}
  />
</BaseLayout>