---
import ToolLayout from '../../layouts/ToolLayout.astro';
import TextareaInput from '../../components/ui/TextareaInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import NumberInput from '../../components/ui/NumberInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Code Beautifier – Format HTML, CSS, JS | MetisTools';
const pageDescription = 'Beautify (pretty print) or minify your HTML, CSS, or JavaScript code. Auto language detection, before/after comparison. Free online code formatter for developers.';

const langOptions = [
  { value: 'auto', label: 'Auto Detect' },
  { value: 'html', label: 'HTML' },
  { value: 'css', label: 'CSS' },
  { value: 'js', label: 'JavaScript' },
];

const actionOptions = [
  { value: 'beautify', label: 'Beautify (Pretty Print)' },
  { value: 'minify', label: 'Minify (Compact)' },
];
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/code-beautifier">
  <div slot="input">
    <div class="space-y-4">
      <TextareaInput id="code-input" label="Code Input" placeholder="Paste your HTML, CSS, or JavaScript here..." rows={8} monospace={true} required={true} />

      <div class="grid grid-cols-2 gap-3">
        <SelectInput id="code-lang" label="Language" options={langOptions} selected="auto" />
        <SelectInput id="code-action" label="Action" options={actionOptions} selected="beautify" />
      </div>

      <NumberInput id="code-indent" label="Indent Size" value="2" min={1} max={8} decimalPlaces={0} helperText="Spaces per indent level (beautify only)" />

      <button type="button" id="btn-process" class="tool-btn-primary w-full">
        Beautify Code
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Paste code and click <strong>Beautify Code</strong> to format or minify." onCopy={true}>
      <div slot="result-content" class="space-y-4">
        <div id="code-output" class="bg-gray-50 rounded-lg p-4 border border-gray-200 font-mono text-xs whitespace-pre-wrap break-all text-gray-800 leading-relaxed max-h-[500px] overflow-y-auto">
        </div>

        <div id="code-stats" class="flex gap-4 text-xs text-gray-400 pt-3 border-t border-gray-100">
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      Clean, well-formatted code is easier to read, debug, and maintain. This tool beautifies (pretty prints) or minifies HTML, CSS, and JavaScript code using battle-tested formatting libraries. All processing happens directly in your browser.
    </p>
    <p>
      <strong>Auto Detect Language:</strong> Not sure what language your code is? The auto-detect mode analyzes your input and automatically applies the correct formatter. It detects HTML by checking for HTML tags, CSS by checking for common CSS patterns, and defaults to JavaScript otherwise.
    </p>
    <p>
      <strong>Beautify (Pretty Print):</strong> Adds proper indentation, line breaks, and spacing to make code readable. Configure the indent size (2, 4, or 8 spaces). This is ideal for formatting minified third-party code, poorly structured legacy code, or code snippets from the web.
    </p>
    <p>
      <strong>Minify (Compact):</strong> Removes all unnecessary whitespace, comments, and formatting to produce the smallest possible file size. Useful for production deployment where bandwidth matters, or when embedding code inline.
    </p>
    <p>
      <strong>Before/After Stats:</strong> See the character count difference between your original code and the processed output — helpful for understanding the impact of minification on file size.
    </p>
  </div>
</ToolLayout>

<script>
  let currentOutput = '';

  function detectLanguage(code) {
    const trimmed = code.trim();
    if (/^\s*</.test(trimmed) || /<!DOCTYPE/i.test(trimmed) || /<html/i.test(trimmed) || /<div/i.test(trimmed) || /<[a-zA-Z][^>]*>/.test(trimmed)) {
      return 'html';
    }
    if (/[{}]/.test(trimmed) && /:\s*[^;]+;/.test(trimmed)) {
      const cssRatio = (trimmed.match(/[:;]/g) || []).length;
      const jsRatio = (trimmed.match(/[{}();]/g) || []).length;
      if (cssRatio > jsRatio) return 'css';
    }
    if (/function\s*\(/.test(trimmed) || /const\s+\w+\s*=/.test(trimmed) || /let\s+\w+\s*=/.test(trimmed) || /var\s+\w+\s*=/.test(trimmed) || /=>\s*\{/.test(trimmed)) {
      return 'js';
    }
    return 'js';
  }

  async function processCode() {
    const input = document.getElementById('code-input')?.value;
    if (!input?.trim()) { showToast('Please paste code to format.', 'error'); return; }

    let lang = document.getElementById('code-lang')?.value || 'auto';
    const action = document.getElementById('code-action')?.value || 'beautify';
    const rawVal = document.getElementById('code-indent')?.value;
    let indentSize = Number(rawVal);
    if (!Number.isFinite(indentSize) || indentSize < 1) indentSize = 2;

    if (lang === 'auto') lang = detectLanguage(input);

    try {
      const beautify = await import('js-beautify');
      const html_beautify = beautify.html_beautify || beautify.default?.html_beautify;
      const css_beautify = beautify.css_beautify || beautify.default?.css_beautify;
      const js_beautify = beautify.js_beautify || beautify.default?.js_beautify;

      let output;
      const beautifyOptions = {
        indent_size: indentSize,
        indent_char: ' ',
      };

      if (action === 'beautify') {
        if (lang === 'html') output = html_beautify(input, beautifyOptions);
        else if (lang === 'css') output = css_beautify(input, beautifyOptions);
        else output = js_beautify(input, beautifyOptions);
      } else {
        if (lang === 'html') {
          output = html_beautify(input, { indent_size: 0, max_preserve_newlines: 0, preserve_newlines: false });
        } else if (lang === 'css') {
          output = css_beautify(input, { indent_size: 0 });
          output = output.replace(/\s+/g, ' ').replace(/\s*([{}:;,])\s*/g, '$1').trim();
        } else {
          output = js_beautify(input, { indent_size: 0 });
          output = output.replace(/^\s+/gm, '').replace(/\n/g, '').replace(/\s+/g, ' ');
        }
      }

      currentOutput = output;

      document.getElementById('result-empty').classList.add('hidden');
      document.getElementById('result-data').classList.remove('hidden');
      document.getElementById('code-output').textContent = output;
      document.getElementById('code-stats').innerHTML = `
        <span>Language: <strong>${lang.toUpperCase()}</strong></span>
        <span>Original: <strong>${input.length}</strong> chars</span>
        <span>Output: <strong>${output.length}</strong> chars</span>
        <span>${action === 'beautify' ? '✓ Beautified' : '✓ Minified'}</span>
      `;
    } catch (e) {
      showToast('Error processing code: ' + e.message, 'error');
    }
  }

  function updateButtonLabel() {
    const action = document.getElementById('code-action')?.value || 'beautify';
    const btn = document.getElementById('btn-process');
    if (btn) btn.textContent = action === 'minify' ? 'Minify Code' : 'Beautify Code';
  }

  document.getElementById('code-action')?.addEventListener('change', updateButtonLabel);
  document.addEventListener('select-change', (e) => {
    if (e.target?.closest('.custom-select-wrapper')?.dataset?.selectId === 'code-action') {
      updateButtonLabel();
    }
  });

  document.getElementById('btn-process')?.addEventListener('click', processCode);

  document.getElementById('btn-copy-result')?.addEventListener('click', () => {
    if (!currentOutput) return;
    navigator.clipboard.writeText(currentOutput).then(() => {
      showToast('Code copied to clipboard!', 'success');
    }).catch(() => showToast('Failed to copy.', 'error'));
  });
</script>
