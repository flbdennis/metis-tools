---
import ToolLayout from '../../layouts/ToolLayout.astro';
import FileUpload from '../../components/ui/FileUpload.astro';
import NumberInput from '../../components/ui/NumberInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import ProgressBar from '../../components/ui/ProgressBar.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Image Cropper & Resizer – Crop, Resize Images | MetisTools';
const pageDescription = 'Crop or resize images to exact dimensions. Free online image editing tool with drag-to-crop and social media presets.';

const ratioOptions = [
  { value: 'free', label: 'Freeform' },
  { value: '1:1', label: 'Square (1:1)' },
  { value: '4:3', label: 'Standard (4:3)' },
  { value: '16:9', label: 'Widescreen (16:9)' },
  { value: '3:2', label: 'Photo (3:2)' },
  { value: '2:3', label: 'Portrait (2:3)' },
  { value: '9:16', label: 'Story (9:16)' },
];

const socialPresets = [
  { label: 'Instagram Post', w: 1080, h: 1080 },
  { label: 'Instagram Story', w: 1080, h: 1920 },
  { label: 'Twitter Post', w: 1200, h: 675 },
  { label: 'Facebook Post', w: 1200, h: 630 },
  { label: 'LinkedIn Post', w: 1200, h: 627 },
  { label: 'YouTube Thumbnail', w: 1280, h: 720 },
];

const rotateOptions = [
  { value: '0', label: 'No Rotation' },
  { value: '90', label: '90° CW' },
  { value: '180', label: '180°' },
  { value: '270', label: '90° CCW' },
];
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/image-crop-resize">
  <div slot="input">
    <div class="space-y-4">
      <FileUpload id="cr-file" label="Upload Image" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" maxSize={100 * 1024 * 1024} required={true} helperText="JPEG, PNG, or WebP — up to 100MB" />

      <!-- Crop Area Selector -->
      <div id="cr-crop-section" class="hidden space-y-3">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Crop</p>
        <SelectInput id="cr-ratio" label="Aspect Ratio" options={ratioOptions} selected="free" />

        <div class="bg-gray-100 rounded-lg border-2 border-dashed border-gray-300 flex items-center justify-center overflow-hidden relative" style="min-height: 200px; max-height: 350px;">
          <canvas id="cr-crop-canvas" class="max-w-full max-h-[350px] cursor-crosshair"></canvas>
        </div>

        <div class="grid grid-cols-4 gap-2">
          <NumberInput id="cr-crop-x" label="X" value="0" min={0} required={false} decimalPlaces={0} />
          <NumberInput id="cr-crop-y" label="Y" value="0" min={0} required={false} decimalPlaces={0} />
          <NumberInput id="cr-crop-w" label="Width" value="0" min={1} required={false} decimalPlaces={0} />
          <NumberInput id="cr-crop-h" label="Height" value="0" min={1} required={false} decimalPlaces={0} />
        </div>
      </div>

      <!-- Resize Section -->
      <details id="cr-resize-section" class="group hidden">
        <summary class="text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:text-gray-700">Resize</summary>
        <div class="mt-3 space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <NumberInput id="cr-resize-w" label="Width (px)" value="" min={1} max={10000} decimalPlaces={0} required={false} helperText="New width" />
            <NumberInput id="cr-resize-h" label="Height (px)" value="" min={1} max={10000} decimalPlaces={0} required={false} helperText="New height" />
          </div>
          <div class="flex flex-wrap gap-1.5">
            {socialPresets.map(p => (
              <button type="button" class="social-chip text-xs bg-gray-100 hover:bg-indigo-100 text-gray-600 hover:text-indigo-700 rounded-full px-2.5 py-1 transition-colors" data-w={p.w} data-h={p.h}>
                {p.label}
              </button>
            ))}
          </div>
        </div>
      </details>

      <!-- Transform Section -->
      <details id="cr-transform-section" class="group hidden">
        <summary class="text-xs font-medium text-gray-500 uppercase tracking-wider cursor-pointer hover:text-gray-700">Transform</summary>
        <div class="mt-3 space-y-3">
          <SelectInput id="cr-rotate" label="Rotate" options={rotateOptions} selected="0" />
          <div class="flex gap-2">
            <button type="button" id="btn-flip-h" class="tool-btn-secondary flex-1 text-xs">Flip Horizontal</button>
            <button type="button" id="btn-flip-v" class="tool-btn-secondary flex-1 text-xs">Flip Vertical</button>
          </div>
        </div>
      </details>

      <button type="button" id="btn-apply" class="tool-btn-primary w-full" disabled>
        Apply Crop
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Upload an image, adjust crop/resize/transform, then click <strong>Apply Crop</strong>.">
      <div slot="result-content" class="space-y-4">
        <ProgressBar visible={false} />

        <div class="bg-gray-100 rounded-lg border border-gray-200 aspect-video flex items-center justify-center overflow-hidden">
          <img id="cr-output-img" src="" alt="Result" class="max-w-full max-h-full object-contain hidden" />
          <span id="cr-output-placeholder" class="text-sm text-gray-400">Result will appear here</span>
        </div>

        <div class="flex gap-4 text-xs text-gray-400 pt-3 border-t border-gray-100">
          <span>Size: <strong id="cr-size">--</strong></span>
          <span>Dimensions: <strong id="cr-dims">--</strong></span>
        </div>

        <!-- Download button below result content -->
        <button type="button" id="btn-download-cr" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-primary-200 bg-primary-50 px-4 py-2.5 text-sm font-medium text-primary-700 hover:bg-primary-100 transition-colors" onclick="downloadResult()">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          Download
        </button>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      This free online image cropper and resizer lets you crop, resize, rotate, and flip images directly in your browser. Your images stay local — nothing is uploaded to any server. All processing uses the Canvas API.
    </p>
    <p>
      <strong>Crop with Preset Ratios:</strong> Choose from common aspect ratios including Square (1:1) for Instagram, Widescreen (16:9) for video thumbnails, Photo (3:2) for prints, and Story (9:16) for stories. Drag on the canvas to select your crop area, and fine-tune with the X/Y/Width/Height inputs.
    </p>
    <p>
      <strong>Resize to Exact Dimensions:</strong> Enter a custom width and height in pixels, or click any social media preset chip (Instagram Post, Twitter, Facebook, LinkedIn, YouTube) to auto-fill the recommended dimensions.
    </p>
    <p>
      <strong>Rotate &amp; Flip:</strong> Rotate in 90° increments or flip horizontally/vertically. All transformations are applied in a single step when you click Apply.
    </p>
    <p>
      <strong>One-Click Download:</strong> Download your edited image in its original format. The result preview shows exact dimensions and file size before you save.
    </p>
  </div>
</ToolLayout>

<script>
  import { loadImage, cropImage, resizeImage, rotateImage, flipImage, formatFileSize } from '../../lib/image-tools.js';

  const showToast = window.showToast || (() => {});
  const updateProgress = window.updateProgress || (() => {});
  const hideProgress = window.hideProgress || (() => {});

  let currentFile = null;
  let currentImg = null;
  let currentResult = null;
  let cropArea = { x: 0, y: 0, w: 1, h: 1 };

  const canvas = document.getElementById('cr-crop-canvas');
  const ctx = canvas?.getContext('2d');

  function clearResults() {
    currentResult = null;
    document.getElementById('result-data').classList.add('hidden');
    document.getElementById('result-empty').classList.remove('hidden');
    document.getElementById('cr-output-img').classList.add('hidden');
    document.getElementById('cr-output-placeholder').classList.remove('hidden');
    document.getElementById('cr-size').textContent = '--';
    document.getElementById('cr-dims').textContent = '--';
    hideProgress();
  }

  window.downloadResult = function() {
    if (!currentResult) return;
    const a = document.createElement('a');
    a.href = currentResult.url;
    a.download = 'edited-' + (currentFile?.name || 'image.png');
    a.click();
  };

  // File selection
  document.getElementById('cr-file')?.addEventListener('file-selected', async (e) => {
    currentFile = e.detail.file;
    clearResults();
    try {
      const { img } = await loadImage(currentFile);
      currentImg = img;
      showEditor();
    } catch (err) {
      showToast('Failed to load image.', 'error');
    }
  });

  document.getElementById('cr-file')?.addEventListener('file-cleared', () => {
    currentFile = null;
    currentImg = null;
    hideEditor();
    clearResults();
  });

  function showEditor() {
    document.getElementById('cr-crop-section').classList.remove('hidden');
    document.getElementById('cr-resize-section').classList.remove('hidden');
    document.getElementById('cr-transform-section').classList.remove('hidden');
    document.getElementById('btn-apply').disabled = false;
    drawCropCanvas();
  }

  function hideEditor() {
    document.getElementById('cr-crop-section').classList.add('hidden');
    document.getElementById('cr-resize-section').classList.add('hidden');
    document.getElementById('cr-transform-section').classList.add('hidden');
    document.getElementById('btn-apply').disabled = true;
  }

  function drawCropCanvas() {
    if (!currentImg || !canvas) return;
    const maxW = 500, maxH = 350;
    let w = currentImg.width, h = currentImg.height;
    if (w > maxW) { h = h * (maxW / w); w = maxW; }
    if (h > maxH) { w = w * (maxH / h); h = maxH; }
    canvas.width = w;
    canvas.height = h;
    ctx.drawImage(currentImg, 0, 0, w, h);

    document.getElementById('cr-crop-x').value = '0';
    document.getElementById('cr-crop-y').value = '0';
    document.getElementById('cr-crop-w').value = Math.round(w);
    document.getElementById('cr-crop-h').value = Math.round(h);
  }

  // Drag to crop
  let dragging = false, dragStart = { x: 0, y: 0 };
  canvas?.addEventListener('mousedown', (e) => {
    dragging = true;
    const rect = canvas.getBoundingClientRect();
    dragStart = { x: e.clientX - rect.left, y: e.clientY - rect.top };
  });
  canvas?.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    drawCropCanvas();
    ctx.strokeStyle = '#4f46e5';
    ctx.lineWidth = 2;
    ctx.setLineDash([6, 3]);
    const x = Math.min(dragStart.x, mx), y = Math.min(dragStart.y, my);
    const w = Math.abs(mx - dragStart.x), h = Math.abs(my - dragStart.y);
    ctx.strokeRect(x, y, w, h);
    ctx.setLineDash([]);
    document.getElementById('cr-crop-x').value = Math.round(x);
    document.getElementById('cr-crop-y').value = Math.round(y);
    document.getElementById('cr-crop-w').value = Math.round(w);
    document.getElementById('cr-crop-h').value = Math.round(h);
  });
  canvas?.addEventListener('mouseup', () => { dragging = false; });
  canvas?.addEventListener('mouseleave', () => { dragging = false; });

  // Aspect ratio constraint via inputs
  function updateCropFromInputs() {
    const ratio = document.getElementById('cr-ratio')?.value || 'free';
    if (ratio === 'free' || !currentImg) return;

    const [rw, rh] = ratio.split(':').map(Number);
    const aspectRatio = rw / rh;

    const wInput = document.getElementById('cr-crop-w');
    const hInput = document.getElementById('cr-crop-h');
    wInput?.addEventListener('input', () => {
      hInput.value = Math.round(parseInt(wInput.value) / aspectRatio);
      drawCropWithOverlay();
    });
    hInput?.addEventListener('input', () => {
      wInput.value = Math.round(parseInt(hInput.value) * aspectRatio);
      drawCropWithOverlay();
    });
  }

  function drawCropWithOverlay() {
    drawCropCanvas();
    const x = parseInt(document.getElementById('cr-crop-x')?.value) || 0;
    const y = parseInt(document.getElementById('cr-crop-y')?.value) || 0;
    const w = parseInt(document.getElementById('cr-crop-w')?.value) || 0;
    const h = parseInt(document.getElementById('cr-crop-h')?.value) || 0;
    ctx.strokeStyle = '#4f46e5';
    ctx.lineWidth = 2;
    ctx.setLineDash([6, 3]);
    ctx.strokeRect(x, y, w, h);
    ctx.setLineDash([]);
  }

  document.getElementById('cr-ratio')?.addEventListener('change', updateCropFromInputs);

  // Social presets
  document.querySelectorAll('.social-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.getElementById('cr-resize-w').value = chip.dataset.w;
      document.getElementById('cr-resize-h').value = chip.dataset.h;
    });
  });

  // Flip buttons
  let flipDir = null;
  document.getElementById('btn-flip-h')?.addEventListener('click', () => flipDir = 'horizontal');
  document.getElementById('btn-flip-v')?.addEventListener('click', () => flipDir = 'vertical');

  // Apply
  async function doApply() {
    if (!currentFile) { showToast('Please upload an image.', 'error'); return; }

    const btn = document.getElementById('btn-apply');
    btn.disabled = true;
    btn.textContent = 'Processing...';

    clearResults();
    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');
    updateProgress(30, 'Applying transformations...');

    try {
      let file = currentFile;
      let url = null;

      // Step 1: Crop
      const cropX = parseInt(document.getElementById('cr-crop-x')?.value) || 0;
      const cropY = parseInt(document.getElementById('cr-crop-y')?.value) || 0;
      const cropW = parseInt(document.getElementById('cr-crop-w')?.value) || (currentImg?.width || 0);
      const cropH = parseInt(document.getElementById('cr-crop-h')?.value) || (currentImg?.height || 0);

      if (currentImg && (cropX > 0 || cropY > 0 || cropW < currentImg.width || cropH < currentImg.height)) {
        updateProgress(45, 'Cropping...');
        const scaleX = currentImg.width / canvas.width;
        const scaleY = currentImg.height / canvas.height;
        const cropResult = await cropImage(file, {
          x: (cropX * scaleX) / currentImg.width,
          y: (cropY * scaleY) / currentImg.height,
          width: (cropW * scaleX) / currentImg.width,
          height: (cropH * scaleY) / currentImg.height,
        });
        url = cropResult.url;
        file = new File([cropResult.blob], 'cropped.png', { type: 'image/png' });
      }

      // Step 2: Resize
      const rw = parseInt(document.getElementById('cr-resize-w')?.value) || 0;
      const rh = parseInt(document.getElementById('cr-resize-h')?.value) || 0;
      if (rw > 0 && rh > 0) {
        updateProgress(60, 'Resizing...');
        const resizeResult = await resizeImage(file, rw, rh, true);
        url = resizeResult.url;
        file = new File([resizeResult.blob], 'resized.png', { type: 'image/png' });
      }

      // Step 3: Rotate
      const rot = parseInt(document.getElementById('cr-rotate')?.value) || 0;
      if (rot > 0) {
        updateProgress(75, 'Rotating...');
        const rotResult = await rotateImage(file, rot);
        url = rotResult.url;
        file = new File([rotResult.blob], 'rotated.png', { type: 'image/png' });
      }

      // Step 4: Flip
      if (flipDir) {
        updateProgress(85, 'Flipping...');
        const flipResult = await flipImage(file, flipDir);
        url = flipResult.url;
        file = new File([flipResult.blob], 'flipped.png', { type: 'image/png' });
        flipDir = null;
      }

      updateProgress(100, 'Done!');

      if (url) {
        currentResult = { url, file, size: file.size, width: 0, height: 0 };
        const img = await loadImage(file);
        currentResult.width = img.img.width;
        currentResult.height = img.img.height;

        document.getElementById('cr-output-img').src = url;
        document.getElementById('cr-output-img').classList.remove('hidden');
        document.getElementById('cr-output-placeholder').classList.add('hidden');
        document.getElementById('cr-size').textContent = formatFileSize(file.size);
        document.getElementById('cr-dims').textContent = `${currentResult.width} x ${currentResult.height}`;
      }

      setTimeout(() => hideProgress(), 1500);
    } catch (err) {
      hideProgress();
      showToast('Processing failed: ' + (err.message || 'Unknown error'), 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Apply Crop';
    }
  }

  document.getElementById('btn-apply')?.addEventListener('click', doApply);
</script>
