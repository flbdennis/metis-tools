---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Lorem Ipsum Generator - Dummy Text Generator";
const description = "Generate random Lorem Ipsum placeholder text for designs, mockups, and content. Choose paragraphs or words.";
---

<BaseLayout title={title} description={description} currentPath="/tools/lorem-ipsum-generator">
  <div class="max-w-2xl mx-auto py-8">
    <div class="bg-white dark:bg-slate-950 rounded-2xl shadow-md p-6 border border-gray-100 dark:border-slate-800">
      <h1 class="text-3xl font-bold mb-2">📝 Lorem Ipsum Generator</h1>
      <p class="text-gray-600 dark:text-gray-300 mb-6">Generate realistic dummy text for your projects.</p>

      <div class="flex gap-4 mb-4">
        <div class="flex-1">
          <label class="block text-sm font-medium mb-1">Unit</label>
          <select id="unit" class="w-full px-4 py-2 rounded-full border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950">
            <option value="paragraphs">Paragraphs</option>
            <option value="words">Words</option>
          </select>
        </div>
        <div class="flex-1">
          <label class="block text-sm font-medium mb-1">Count</label>
          <input type="number" id="count" min="1" max="50" value="3" class="w-full px-4 py-2 rounded-full border border-gray-300 dark:border-slate-700 text-center text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950">
        </div>
      </div>
      <button id="generate-btn" class="w-full bg-indigo-600 dark:bg-indigo-500 text-white py-2 rounded-full mb-4">Generate</button>
      <textarea id="output" rows="8" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-slate-700 font-sans text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950" readonly placeholder="Generated text will appear here..."></textarea>
      <button id="copy-btn" class="mt-2 bg-gray-200 dark:bg-slate-800 hover:bg-gray-300 dark:hover:bg-slate-700 px-4 py-2 rounded-full text-sm">Copy Text</button>
    </div>
  </div>

  <script>
    const unitSelect = document.getElementById('unit');
    const countInput = document.getElementById('count');
    const generateBtn = document.getElementById('generate-btn');
    const output = document.getElementById('output');
    const copyBtn = document.getElementById('copy-btn');

    const words = [
      "lorem", "ipsum", "dolor", "sit", "amet", "consectetur", "adipiscing", "elit", "sed", "do",
      "eiusmod", "tempor", "incididunt", "ut", "labore", "et", "dolore", "magna", "aliqua", "ut",
      "enim", "ad", "minim", "veniam", "quis", "nostrud", "exercitation", "ullamco", "laboris", "nisi",
      "ut", "aliquip", "ex", "ea", "commodo", "consequat", "duis", "aute", "irure", "dolor", "in",
      "reprehenderit", "in", "voluptate", "velit", "esse", "cillum", "dolore", "eu", "fugiat", "nulla",
      "pariatur", "excepteur", "sint", "occaecat", "cupidatat", "non", "proident", "sunt", "in", "culpa",
      "qui", "officia", "deserunt", "mollit", "anim", "id", "est", "laborum"
    ];

    function getRandomWord() {
      return words[Math.floor(Math.random() * words.length)];
    }

    function generateParagraph(wordCount = 80) {
      const pWords = [];
      for (let i = 0; i < wordCount; i++) {
        pWords.push(getRandomWord());
      }
      let sentence = pWords.join(' ');
      sentence = sentence.charAt(0).toUpperCase() + sentence.slice(1);
      if (!sentence.endsWith('.')) sentence += '.';
      return sentence;
    }

    function generateText() {
      const unit = unitSelect.value;
      let count = parseInt(countInput.value);
      if (isNaN(count) || count < 1) count = 1;
      if (count > 50) count = 50;
      let result = '';
      if (unit === 'paragraphs') {
        const paras = [];
        for (let i = 0; i < count; i++) {
          paras.push(generateParagraph(60 + Math.floor(Math.random() * 40)));
        }
        result = paras.join('\n\n');
      } else {
        const wordList = [];
        for (let i = 0; i < count; i++) {
          wordList.push(getRandomWord());
        }
        result = wordList.join(' ');
        result = result.charAt(0).toUpperCase() + result.slice(1);
      }
      output.value = result;
    }

    generateBtn.addEventListener('click', generateText);
    copyBtn.addEventListener('click', () => {
      if (output.value) {
        navigator.clipboard.writeText(output.value).then(() => showMessage('Copied!', 'success')).catch(() => showMessage('Copy failed', 'error'));
      } else {
        showMessage('Nothing to copy', 'error');
      }
    });
    generateText(); // 初始生成
  </script>
  <Schema
    toolName="Lorem Ipsum Generator"
    description={description}
    url={Astro.url.href}
  />
</BaseLayout>