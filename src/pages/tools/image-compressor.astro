---
import ToolLayout from '../../layouts/ToolLayout.astro';
import FileUpload from '../../components/ui/FileUpload.astro';
import NumberInput from '../../components/ui/NumberInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import ProgressBar from '../../components/ui/ProgressBar.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Image Compressor – Reduce JPG, PNG, WebP Size | MetisTools';
const pageDescription = 'Compress JPEG, PNG, WebP images online without losing quality. Free image compressor for web optimization, email attachments, and storage.';

const qualityOptions = [
  { value: '0.9', label: 'High (90%) — Best Quality' },
  { value: '0.7', label: 'Medium (70%) — Balanced' },
  { value: '0.5', label: 'Low (50%) — Maximum Compression' },
  { value: 'custom', label: 'Custom' },
];
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/image-compressor">
  <div slot="input">
    <div class="space-y-4">
      <FileUpload id="ic-file" label="Upload Image" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" maxSize={100 * 1024 * 1024} required={true} helperText="JPEG, PNG, or WebP — up to 100MB" />

      <SelectInput id="ic-quality-preset" label="Quality Preset" options={qualityOptions} selected="0.7" />

      <div id="ic-custom-quality" class="hidden">
        <NumberInput id="ic-quality" label="Custom Quality" value="80" min={1} max={100} decimalPlaces={0} allowNegative={false} required={false} helperText="1 – 100 (higher = better quality, larger file)" />
      </div>

      <button type="button" id="btn-compress" class="tool-btn-primary w-full" disabled>
        Compress Image
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Upload an image and click <strong>Compress Image</strong> to see results." onDownload={true}>
      <div slot="result-content" class="space-y-4">
        <ProgressBar visible={false} />

        <!-- Before / After preview -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Original</h4>
            <div class="bg-gray-100 rounded-lg border border-gray-200 aspect-square flex items-center justify-center overflow-hidden">
              <img id="ic-original-img" src="" alt="Original" class="max-w-full max-h-full object-contain hidden" />
              <span id="ic-original-placeholder" class="text-xs text-gray-400">--</span>
            </div>
            <div id="ic-original-info" class="mt-1 text-xs text-gray-500"></div>
          </div>
          <div>
            <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Compressed</h4>
            <div class="bg-gray-100 rounded-lg border border-gray-200 aspect-square flex items-center justify-center overflow-hidden">
              <img id="ic-compressed-img" src="" alt="Compressed" class="max-w-full max-h-full object-contain hidden" />
              <span id="ic-compressed-placeholder" class="text-xs text-gray-400">--</span>
            </div>
            <div id="ic-compressed-info" class="mt-1 text-xs text-gray-500"></div>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-3 text-center">
          <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
            <div id="ic-saved" class="text-lg font-bold text-emerald-600">--</div>
            <div class="text-xs text-gray-500">Saved</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
            <div id="ic-orig-size" class="text-lg font-bold text-gray-700">--</div>
            <div class="text-xs text-gray-500">Original Size</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-3 border border-gray-100">
            <div id="ic-new-size" class="text-lg font-bold text-gray-700">--</div>
            <div class="text-xs text-gray-500">New Size</div>
          </div>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      This free online image compressor reduces the file size of JPEG, PNG, and WebP images directly in your browser. Your images are never uploaded to any server — all compression happens locally using the Canvas API, keeping your data private and secure.
    </p>
    <p>
      <strong>Quality Control:</strong> Choose from High (90%), Medium (70%), or Low (50%) quality presets, or set a custom quality level from 1 to 100. Higher quality means larger files; lower quality means more compression and smaller files.
    </p>
    <p>
      <strong>Before/After Preview:</strong> Compare the original and compressed images side by side to visually verify that quality is preserved. Check the exact file size difference and the percentage saved.
    </p>
    <p>
      <strong>Supports Multiple Formats:</strong> Works with JPEG (.jpg), PNG (.png), and WebP (.webp) images up to 100MB. The output format matches the input format by default, so your compressed image stays compatible with your workflow.
    </p>
    <p>
      <strong>Use Cases:</strong> Optimize website images for faster page loads and better SEO. Reduce email attachment sizes to stay under limits. Free up storage space on your device by compressing photos. Prepare images for social media where file size limits apply.
    </p>
  </div>
</ToolLayout>

<script>
  import { compressImage, formatFileSize } from '../../lib/image-tools.js';

  const showToast = window.showToast || (() => {});
  const updateProgress = window.updateProgress || (() => {});
  const hideProgress = window.hideProgress || (() => {});

  let currentFile = null;
  let currentResult = null;

  function clearResults() {
    currentResult = null;
    document.getElementById('result-data').classList.add('hidden');
    document.getElementById('result-empty').classList.remove('hidden');
    document.getElementById('ic-compressed-img').classList.add('hidden');
    document.getElementById('ic-compressed-placeholder').classList.remove('hidden');
    document.getElementById('ic-compressed-info').textContent = '';
    document.getElementById('ic-saved').textContent = '--';
    document.getElementById('ic-orig-size').textContent = '--';
    document.getElementById('ic-new-size').textContent = '--';
    hideProgress();
  }

  function toggleCustomQuality() {
    const preset = document.getElementById('ic-quality-preset')?.value;
    const customDiv = document.getElementById('ic-custom-quality');
    if (preset === 'custom') {
      customDiv.classList.remove('hidden');
    } else {
      customDiv.classList.add('hidden');
    }
  }

  document.getElementById('ic-quality-preset')?.addEventListener('change', toggleCustomQuality);
  document.addEventListener('select-change', (e) => {
    if (e.target?.closest('.custom-select-wrapper')?.dataset?.selectId === 'ic-quality-preset') {
      toggleCustomQuality();
    }
  });

  // File selection handler
  document.getElementById('ic-file')?.addEventListener('file-selected', (e) => {
    currentFile = e.detail.file;
    clearResults();
    document.getElementById('btn-compress').disabled = false;
    const reader = new FileReader();
    reader.onload = (ev) => {
      document.getElementById('ic-original-img').src = ev.target.result;
      document.getElementById('ic-original-img').classList.remove('hidden');
      document.getElementById('ic-original-placeholder').classList.add('hidden');
      document.getElementById('ic-original-info').textContent = `${currentFile.name} — ${formatFileSize(currentFile.size)}`;
    };
    reader.readAsDataURL(currentFile);
  });

  document.getElementById('ic-file')?.addEventListener('file-cleared', () => {
    currentFile = null;
    document.getElementById('btn-compress').disabled = true;
    document.getElementById('ic-original-img').classList.add('hidden');
    document.getElementById('ic-original-placeholder').classList.remove('hidden');
    document.getElementById('ic-original-info').textContent = '';
    clearResults();
  });

  async function doCompress() {
    if (!currentFile) { showToast('Please select an image.', 'error'); return; }

    const btn = document.getElementById('btn-compress');
    btn.disabled = true;
    btn.textContent = 'Compressing...';

    clearResults();
    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');
    updateProgress(50, 'Compressing image...');

    try {
      const preset = document.getElementById('ic-quality-preset')?.value;
      let quality = preset === 'custom'
        ? (parseInt(document.getElementById('ic-quality')?.value) || 80) / 100
        : parseFloat(preset || '0.7');

      currentResult = await compressImage(currentFile, quality);

      updateProgress(100, 'Done!');

      document.getElementById('ic-compressed-img').src = currentResult.url;
      document.getElementById('ic-compressed-img').classList.remove('hidden');
      document.getElementById('ic-compressed-placeholder').classList.add('hidden');
      document.getElementById('ic-compressed-info').textContent = `${formatFileSize(currentResult.compressedSize)} — ${currentResult.width}x${currentResult.height}`;

      document.getElementById('ic-saved').textContent = currentResult.savedPercent + '%';
      document.getElementById('ic-orig-size').textContent = formatFileSize(currentResult.originalSize);
      document.getElementById('ic-new-size').textContent = formatFileSize(currentResult.compressedSize);

      setTimeout(() => hideProgress(), 1500);
    } catch (e) {
      hideProgress();
      showToast('Compression failed: ' + (e.message || 'Unknown error'), 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Compress Image';
    }
  }

  document.getElementById('btn-compress')?.addEventListener('click', doCompress);

  document.getElementById('btn-download-result')?.addEventListener('click', () => {
    if (!currentResult) return;
    const a = document.createElement('a');
    a.href = currentResult.url;
    a.download = 'compressed-' + (currentFile?.name || 'image');
    a.click();
  });
</script>
