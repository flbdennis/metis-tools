---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { encoders } from '../../lib/text-tools';

const title = "Encode / Decode - Base64, URL, HTML";
const description = "Encode and decode Base64, URL, HTML entities online. Free, private, no data leaves your browser.";
---

<BaseLayout title={title} description={description} currentPath="/text-tools/encode-decode">
  <div class="max-w-4xl mx-auto py-8">
    <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-100">
      <h1 class="text-3xl font-bold mb-2">🔐 Encode / Decode</h1>
      <p class="text-gray-600 mb-6">Select a method, enter text, and click the corresponding button.</p>

      <div class="flex flex-wrap gap-2 mb-4">
        <button data-method="base64Encode" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">Base64 Encode</button>
        <button data-method="base64Decode" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">Base64 Decode</button>
        <button data-method="urlEncode" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">URL Encode</button>
        <button data-method="urlDecode" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">URL Decode</button>
        <button data-method="htmlEncode" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">HTML Encode</button>
        <button data-method="htmlDecode" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">HTML Decode</button>
      </div>

      <textarea id="input-text" rows="6" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono" placeholder="Enter text to encode/decode..."></textarea>

      <div class="mt-4">
        <label class="block text-sm font-medium mb-1">Result</label>
        <textarea id="output-text" rows="6" class="w-full px-4 py-3 rounded-xl border border-gray-300 bg-gray-50 font-mono" readonly placeholder="Result will appear here..."></textarea>
        <button id="copy-btn" class="mt-2 bg-indigo-600 text-white px-4 py-2 rounded-full text-sm">Copy Result</button>
      </div>
    </div>
  </div>

  <script>
    import { encoders } from '../../lib/text-tools';

    const inputEl = document.getElementById('input-text');
    const outputEl = document.getElementById('output-text');
    const copyBtn = document.getElementById('copy-btn');

    function process(method) {
      const text = inputEl.value;
      if (!text.trim()) {
        outputEl.value = '';
        return;
      }
      try {
        const result = encoders[method](text);
        outputEl.value = result;
      } catch (err) {
        outputEl.value = `Error: ${err.message}`;
      }
    }

    const buttons = document.querySelectorAll('[data-method]');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const method = btn.getAttribute('data-method');
        process(method);
      });
    });

    copyBtn.addEventListener('click', () => {
      if (outputEl.value && !outputEl.value.startsWith('Error')) {
        navigator.clipboard.writeText(outputEl.value).then(() => {
          showMessage('Copied to clipboard!', 'success');
        }).catch(() => {
          showMessage('Failed to copy.', 'error');
        });
      } else {
        showMessage('Nothing to copy or invalid result.', 'error');
      }
    });
  </script>
  <Schema
    toolName="Encode/Decode"
    description={description}
    url={Astro.url.href}
  />
</BaseLayout>