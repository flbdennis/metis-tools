---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { textStats } from '../../lib/text-tools';

const title = "Text Statistics - Word, Character, Line Counter";
const description = "Count words, characters, lines in your text instantly. Free and private.";
---

<BaseLayout title={title} description={description} currentPath="/text-tools/text-statistics">
  <div class="max-w-4xl mx-auto py-8">
    <div class="bg-white dark:bg-slate-950 rounded-2xl shadow-md p-6 border border-gray-100 dark:border-slate-800">
      <h1 class="text-3xl font-bold mb-2">📊 Text Statistics</h1>
      <p class="text-gray-600 dark:text-gray-300 mb-6">Type or paste your text to see real-time counts.</p>

      <textarea id="input-text" rows="10" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950" placeholder="Type or paste your text here..."></textarea>

      <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4 text-center">
        <div class="bg-gray-50 dark:bg-slate-950 rounded-xl p-4">
          <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400" id="word-count">0</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Words</p>
        </div>
        <div class="bg-gray-50 dark:bg-slate-950 rounded-xl p-4">
          <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400" id="char-count">0</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Characters</p>
        </div>
        <div class="bg-gray-50 dark:bg-slate-950 rounded-xl p-4">
          <p class="text-3xl font-bold text-indigo-600 dark:text-indigo-400" id="line-count">0</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Lines</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { textStats } from '../../lib/text-tools';

    const inputEl = document.getElementById('input-text');
    const wordSpan = document.getElementById('word-count');
    const charSpan = document.getElementById('char-count');
    const lineSpan = document.getElementById('line-count');

    function updateStats() {
      const text = inputEl.value;
      const stats = textStats(text);
      wordSpan.textContent = stats.words;
      charSpan.textContent = stats.characters;
      lineSpan.textContent = stats.lines;
    }

    inputEl.addEventListener('input', updateStats);
    updateStats(); // initial
  </script>
  <Schema
    toolName="Text Statistics"
    description={description}
    url={Astro.url.href}
    category="TextUtility"
  />
</BaseLayout>