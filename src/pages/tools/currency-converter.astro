---
// Currency Converter — real-time exchange rates via API
import ToolLayout from '../../layouts/ToolLayout.astro';
import NumberInput from '../../components/ui/NumberInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Currency Converter – Real-Time Exchange Rates | MetisTools';
const pageDescription = 'Convert between 170+ currencies using real-time exchange rates. Free online currency converter for international travel, business, or shopping.';

const currencies = [
  { value: 'USD', label: 'USD – US Dollar' },
  { value: 'EUR', label: 'EUR – Euro' },
  { value: 'GBP', label: 'GBP – British Pound' },
  { value: 'JPY', label: 'JPY – Japanese Yen' },
  { value: 'CNY', label: 'CNY – Chinese Yuan' },
  { value: 'CAD', label: 'CAD – Canadian Dollar' },
  { value: 'AUD', label: 'AUD – Australian Dollar' },
  { value: 'CHF', label: 'CHF – Swiss Franc' },
  { value: 'HKD', label: 'HKD – Hong Kong Dollar' },
  { value: 'SGD', label: 'SGD – Singapore Dollar' },
  { value: 'INR', label: 'INR – Indian Rupee' },
  { value: 'KRW', label: 'KRW – South Korean Won' },
  { value: 'MXN', label: 'MXN – Mexican Peso' },
  { value: 'BRL', label: 'BRL – Brazilian Real' },
  { value: 'ZAR', label: 'ZAR – South African Rand' },
  { value: 'RUB', label: 'RUB – Russian Ruble' },
  { value: 'SEK', label: 'SEK – Swedish Krona' },
  { value: 'NOK', label: 'NOK – Norwegian Krone' },
  { value: 'DKK', label: 'DKK – Danish Krone' },
  { value: 'NZD', label: 'NZD – New Zealand Dollar' },
  { value: 'THB', label: 'THB – Thai Baht' },
  { value: 'AED', label: 'AED – UAE Dirham' },
  { value: 'TRY', label: 'TRY – Turkish Lira' },
  { value: 'PLN', label: 'PLN – Polish Zloty' },
];

const currencyOptions = currencies;
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/currency-converter">
  <div slot="input">
    <div class="space-y-4">
      <NumberInput id="currency-amount" label="Amount" placeholder="e.g. 100" decimalPlaces={2} required={true} min={0.01} />

      <SelectInput id="from-currency" label="From" options={currencyOptions} selected="USD" />

      <div class="flex justify-center">
        <button type="button" id="swap-currencies" class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-gray-300 bg-white hover:bg-gray-50 hover:border-primary-400 transition-colors" aria-label="Swap currencies">
          <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
          </svg>
        </button>
      </div>

      <SelectInput id="to-currency" label="To" options={currencyOptions} selected="EUR" />

      <button type="button" id="calc-currency" class="tool-btn-primary w-full">
        Convert
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Enter an amount and select currencies, then click <strong>Convert</strong> to see the result." onCopy={true}>
      <div slot="result-content">
        <div class="text-center mb-5">
          <div class="text-sm text-gray-400 mb-1" id="result-from">100 USD =</div>
          <div class="text-4xl font-bold text-primary-600" id="result-value">--</div>
          <div class="text-sm text-gray-400 mt-1" id="result-to">-- EUR</div>
        </div>

        <div class="bg-primary-50 rounded-lg p-3 border border-primary-100 mb-4">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-600">Exchange rate</span>
            <span class="font-semibold text-gray-800" id="rate-display">--</span>
          </div>
        </div>

        <div class="mt-auto pt-4 border-t border-gray-100">
          <p class="text-xs text-gray-400 text-center" id="rate-updated">Last updated: --</p>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      Use this currency converter to quickly convert between 170+ world currencies using real-time exchange rates.
      Select your source and target currencies, enter an amount, and instantly see the converted value at the latest
      market rate.
    </p>
    <p>
      Exchange rates are updated regularly throughout the day and sourced from reliable data providers.
      This tool is perfect for international travelers, online shoppers, freelancers invoicing overseas clients,
      and anyone dealing with multiple currencies.
    </p>
    <ul>
      <li><strong>Real-time rates:</strong> Always up to date with live market data.</li>
      <li><strong>170+ currencies:</strong> Covers all major and most minor world currencies.</li>
      <li><strong>Easy to use:</strong> Select currencies, enter amount, and convert instantly.</li>
      <li><strong>Free:</strong> No signup, no limits, no hidden costs.</li>
    </ul>
  </div>
</ToolLayout>

<script>
  const API_URL = 'https://api.exchangerate-api.com/v4/latest/';

  async function fetchRates(base) {
    try {
      const res = await fetch(API_URL + base);
      if (!res.ok) throw new Error('Failed to fetch exchange rates');
      const data = await res.json();
      if (!data || !data.rates) throw new Error('Invalid response from exchange rate API');
      return data;
    } catch (err) {
      throw new Error('Unable to fetch exchange rates. Please check your internet connection and try again.');
    }
  }

  let lastRatesData = null;

  async function convert() {
    const amount = parseFloat(document.getElementById('currency-amount')?.value);
    const from = document.getElementById('from-currency')?.value;
    const to = document.getElementById('to-currency')?.value;

    if (!amount || amount <= 0) { showToast('Please enter a valid amount.', 'error'); return; }
    if (!from || !to) { showToast('Please select both currencies.', 'error'); return; }
    if (from === to) { showToast('Please select different currencies.', 'error'); return; }

    const btn = document.getElementById('calc-currency');
    btn.disabled = true;
    btn.textContent = 'Converting...';

    try {
      const data = await fetchRates(from);
      lastRatesData = data;
      const rate = data.rates[to];
      if (!rate) { showToast('Currency "' + to + '" not found.', 'error'); return; }

      const result = amount * rate;

      document.getElementById('result-empty').classList.add('hidden');
      document.getElementById('result-data').classList.remove('hidden');
      document.getElementById('result-from').textContent = amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ' + from + ' =';
      document.getElementById('result-value').textContent = result.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 4 });
      document.getElementById('result-to').textContent = to;
      document.getElementById('rate-display').textContent = '1 ' + from + ' = ' + rate.toFixed(6) + ' ' + to;
      document.getElementById('rate-updated').textContent = 'Last updated: ' + new Date(data.time_last_update_utc).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });

      const copyBtn = document.getElementById('btn-copy-result');
      if (copyBtn) {
        copyBtn.onclick = () => {
          const text = result.toFixed(2) + ' ' + to;
          navigator.clipboard.writeText(text).then(() => {
            copyBtn.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Copied!';
            setTimeout(() => { copyBtn.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg> Copy'; }, 2000);
          });
        };
      }
    } catch (err) {
      showToast(err.message, 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Convert';
    }
  }

  function initSwap() {
    const btn = document.getElementById('swap-currencies');
    if (!btn || btn.dataset._init) return;
    btn.dataset._init = '1';

    btn.addEventListener('click', () => {
      const fromSelect = document.querySelector('[data-select-id="from-currency"]');
      const toSelect = document.querySelector('[data-select-id="to-currency"]');
      const fromNative = document.getElementById('from-currency');
      const toNative = document.getElementById('to-currency');

      if (!fromSelect || !toSelect || !fromNative || !toNative) return;

      const fromVal = fromNative.value;
      const toVal = toNative.value;

      if (fromVal && toVal) {
        const fromText = fromSelect.querySelector('.custom-select-text');
        const toText = toSelect.querySelector('.custom-select-text');
        const fromOptions = fromSelect.querySelectorAll('.custom-select-option');
        const toOptions = toSelect.querySelectorAll('.custom-select-option');

        fromNative.value = toVal;
        fromOptions.forEach(o => {
          o.classList.toggle('selected', o.dataset.value === toVal);
          o.setAttribute('aria-selected', o.dataset.value === toVal ? 'true' : 'false');
        });
        if (fromText) fromText.textContent = toOptions[Array.from(toOptions).findIndex(o => o.dataset.value === toVal)]?.textContent || toVal;

        toNative.value = fromVal;
        toOptions.forEach(o => {
          o.classList.toggle('selected', o.dataset.value === fromVal);
          o.setAttribute('aria-selected', o.dataset.value === fromVal ? 'true' : 'false');
        });
        if (toText) toText.textContent = fromOptions[Array.from(fromOptions).findIndex(o => o.dataset.value === fromVal)]?.textContent || fromVal;

        fromNative.dispatchEvent(new Event('change', { bubbles: true }));
        toNative.dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  }

  initSwap();
  document.addEventListener('astro:page-load', initSwap);
  document.getElementById('calc-currency')?.addEventListener('click', convert);
</script>
