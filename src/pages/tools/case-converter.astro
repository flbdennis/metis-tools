---
import ToolLayout from '../../layouts/ToolLayout.astro';
import TextareaInput from '../../components/ui/TextareaInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Case Converter – Convert Text to Uppercase, Lowercase, etc. | MetisTools';
const pageDescription = 'Convert text to uppercase, lowercase, sentence case, title case, camelCase, PascalCase, snake_case, and kebab-case. Free online case converter.';

const caseOptions = [
  { value: 'uppercase', label: 'UPPERCASE' },
  { value: 'lowercase', label: 'lowercase' },
  { value: 'sentencecase', label: 'Sentence case' },
  { value: 'titlecase', label: 'Title Case' },
  { value: 'camelcase', label: 'camelCase' },
  { value: 'pascalcase', label: 'PascalCase' },
  { value: 'snakecase', label: 'snake_case' },
  { value: 'kebabcase', label: 'kebab-case' },
];
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/case-converter">
  <div slot="input">
    <div class="space-y-4">
      <TextareaInput id="cc-input" label="Enter Text" placeholder="Type or paste your text here..." rows={6} required={true} />

      <SelectInput id="cc-type" label="Convert To" options={caseOptions} selected="lowercase" />

      <button type="button" id="btn-convert" class="tool-btn-primary w-full">
        Convert Case
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Enter text, choose a case style, and click <strong>Convert Case</strong>." onCopy={true} onDownload={true}>
      <div slot="result-content" class="space-y-4">
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div id="cc-output" class="text-sm font-mono text-gray-800 whitespace-pre-wrap break-all leading-relaxed max-h-[400px] overflow-y-auto"></div>
        </div>

        <div class="flex gap-4 text-xs text-gray-400 pt-3 border-t border-gray-100">
          <span>Original: <strong id="cc-orig-len">0</strong> chars</span>
          <span>Result: <strong id="cc-result-len">0</strong> chars</span>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      This free online case converter instantly transforms text between common letter cases and naming styles. Whether you're a developer standardizing variable names or a writer adjusting formatting, all conversions happen right in your browser — no data is ever sent to a server.
    </p>
    <p>
      <strong>Letter Cases:</strong> <em>UPPERCASE</em> makes every letter capital. <em>lowercase</em> makes every letter small. <em>Sentence case</em> capitalizes the first letter of each sentence. <em>Title Case</em> capitalizes the first letter of every word.
    </p>
    <p>
      <strong>Naming Styles (for developers):</strong> <em>camelCase</em> is the standard for JavaScript and Java variable names. <em>PascalCase</em> is used for C# and TypeScript class names. <em>snake_case</em> is common in Python and Ruby. <em>kebab-case</em> is used in CSS class names and URLs.
    </p>
    <p>
      Each conversion handles whitespace normalization and special characters appropriately, giving you clean, predictable output every time. The character count comparison helps you see how the conversion affects text length.
    </p>
  </div>
</ToolLayout>

<script>
  import { caseConverters, namingConverters } from '../../lib/text-tools.js';

  const allConverters = { ...caseConverters, ...namingConverters };
  let currentResult = '';

  function doConvert() {
    const input = document.getElementById('cc-input')?.value || '';
    if (!input.trim()) {
      showToast('Please enter some text.', 'error');
      return;
    }

    const type = document.getElementById('cc-type')?.value || 'lowercase';
    const fn = allConverters[type];
    if (!fn) {
      showToast('Unknown case type.', 'error');
      return;
    }

    currentResult = fn(input);

    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');
    document.getElementById('cc-output').textContent = currentResult;
    document.getElementById('cc-orig-len').textContent = input.length;
    document.getElementById('cc-result-len').textContent = currentResult.length;
  }

  document.getElementById('btn-convert')?.addEventListener('click', doConvert);

  document.getElementById('btn-copy-result')?.addEventListener('click', () => {
    if (!currentResult) return;
    navigator.clipboard.writeText(currentResult).then(() => {
      showToast('Copied to clipboard!', 'success');
    }).catch(() => showToast('Failed to copy.', 'error'));
  });

  document.getElementById('btn-download-result')?.addEventListener('click', () => {
    if (!currentResult) return;
    const blob = new Blob([currentResult], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'converted-text.txt';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
