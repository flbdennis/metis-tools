---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Case Converter - Convert Text to Different Cases";
const description = "Convert text to uppercase, lowercase, sentence case, title case, camelCase, PascalCase, snake_case, kebab-case online. Free and private.";
---

<BaseLayout title={title} description={description} currentPath="/text-tools/case-converter">
  <div class="max-w-4xl mx-auto py-8">
    <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-100">
      <h1 class="text-3xl font-bold mb-2">🔠 Case & Naming Converter</h1>
      <p class="text-gray-600 mb-6">Enter text below, click any button to convert. Your text never leaves your browser.</p>

      <textarea id="input-text" rows="6" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono" placeholder="Type or paste your text here..."></textarea>

      <div class="mt-4 flex flex-wrap gap-2">
        <button data-convert="uppercase" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">UPPERCASE</button>
        <button data-convert="lowercase" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">lowercase</button>
        <button data-convert="sentencecase" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">Sentence case</button>
        <button data-convert="titlecase" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">Title Case</button>
        <button data-convert="camelcase" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">camelCase</button>
        <button data-convert="pascalcase" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">PascalCase</button>
        <button data-convert="snakecase" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">snake_case</button>
        <button data-convert="kebabcase" class="bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm font-medium">kebab-case</button>
      </div>

      <div class="mt-4">
        <label class="block text-sm font-medium mb-1">Result</label>
        <textarea id="output-text" rows="6" class="w-full px-4 py-3 rounded-xl border border-gray-300 bg-gray-50 font-mono" readonly placeholder="Converted text will appear here..."></textarea>
        <button id="copy-btn" class="mt-2 bg-indigo-600 text-white px-4 py-2 rounded-full text-sm">Copy Result</button>
      </div>
    </div>
  </div>

  <script>
    import { caseConverters, namingConverters } from '../../lib/text-tools';

    const inputEl = document.getElementById('input-text');
    const outputEl = document.getElementById('output-text');
    const copyBtn = document.getElementById('copy-btn');

    function convert(converterName) {
      const text = inputEl.value;
      if (!text.trim()) {
        outputEl.value = '';
        return;
      }
      let result = '';
      if (caseConverters[converterName]) {
        result = caseConverters[converterName](text);
      } else if (namingConverters[converterName]) {
        result = namingConverters[converterName](text);
      } else {
        result = text;
      }
      outputEl.value = result;
    }

    const buttons = document.querySelectorAll('[data-convert]');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const converterName = btn.getAttribute('data-convert');
        convert(converterName);
      });
    });

    copyBtn.addEventListener('click', () => {
      if (outputEl.value) {
        navigator.clipboard.writeText(outputEl.value).then(() => {
          showMessage('Copied to clipboard!', 'success');
        }).catch(() => {
          showMessage('Failed to copy.', 'error');
        });
      } else {
        showMessage('Nothing to copy.', 'error');
      }
    });
  </script>
  <Schema
    toolName="Case Converter"
    description={description}
    url={Astro.url.href}
  />
</BaseLayout>