---
// 贷款计算器页面 —— 月供、总利息、还款计划表、提前还款对比
import ToolLayout from '../../layouts/ToolLayout.astro';
import NumberInput from '../../components/ui/NumberInput.astro';
import SelectInput from '../../components/ui/SelectInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'Loan Calculator — Calculate Monthly Payments & Amortization';
const pageDescription = 'Calculate monthly payments, total interest, and amortization schedule. Includes extra payment options and payoff acceleration analysis.';

const frequencyOptions = [
  { value: '12', label: 'Monthly' },
  { value: '26', label: 'Bi-weekly' },
  { value: '52', label: 'Weekly' },
];
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/loan-calculator">
  <div slot="input">
    <div class="space-y-4">
      <NumberInput id="loan-amount" label="Loan Amount" placeholder="e.g. 250000" decimalPlaces={0} required={true} helperText="💰" />
      <NumberInput id="interest-rate" label="Annual Interest Rate" placeholder="e.g. 6.5" decimalPlaces={2} required={true} helperText="%" />
      <NumberInput id="loan-term" label="Loan Term" placeholder="e.g. 30" decimalPlaces={0} required={true} helperText="years" />
      <SelectInput id="payment-frequency" label="Payment Frequency" options={frequencyOptions} selected="12" />
      <NumberInput id="extra-payment" label="Extra Payment (optional)" placeholder="e.g. 200" decimalPlaces={0} helperText="💰 per period" />
      <button type="button" id="calc-loan" class="tool-btn-primary w-full">Calculate</button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Enter your loan details and click <strong>Calculate</strong> to see the payment breakdown.">
      <div slot="result-content">
        <div class="text-center mb-4">
          <div class="text-3xl font-bold text-primary-600" id="monthly-payment">--</div>
          <div class="text-xs text-gray-400 mt-1" id="payment-label">monthly payment</div>
        </div>

        <div class="grid grid-cols-2 gap-2 mb-4">
          <div class="bg-primary-50 rounded-lg p-3 text-center border border-primary-100">
            <div class="text-base font-bold text-primary-700" id="total-payments">--</div>
            <div class="text-[10px] text-primary-500">total payments</div>
          </div>
          <div class="bg-yellow-50 rounded-lg p-3 text-center border border-yellow-100">
            <div class="text-base font-bold text-yellow-700" id="total-interest">--</div>
            <div class="text-[10px] text-yellow-600">total interest</div>
          </div>
        </div>

        <div class="bg-gray-50 rounded-lg p-3 mb-4">
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Total Cost (Principal + Interest)</span>
            <span class="font-semibold text-gray-800" id="total-cost">--</span>
          </div>
        </div>

        <div id="extra-comparison" class="hidden border border-green-200 bg-green-50 rounded-lg p-3 mb-4">
          <div class="text-xs font-semibold text-green-700 mb-2">With Extra Payments</div>
          <div class="space-y-1 text-sm">
            <div class="flex justify-between"><span class="text-green-700">Payoff time</span><span class="font-semibold text-green-800" id="extra-payoff-time">--</span></div>
            <div class="flex justify-between"><span class="text-green-700">Interest saved</span><span class="font-semibold text-green-800" id="interest-saved">--</span></div>
          </div>
        </div>

        <div class="mt-auto">
          <div class="text-xs text-gray-500 mb-1">Payment Breakdown</div>
          <div class="flex h-3 rounded-full overflow-hidden bg-gray-200">
            <div class="bg-primary-500" id="principal-bar" style="width:70%"></div>
            <div class="bg-yellow-400" id="interest-bar" style="width:30%"></div>
          </div>
          <div class="flex justify-between text-[10px] text-gray-400 mt-1">
            <span>Principal <span id="principal-pct">--</span></span>
            <span>Interest <span id="interest-pct">--</span></span>
          </div>
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      Calculate your loan payment, total interest, and see your payment breakdown. Enter the loan amount,
      interest rate, and term. Use the extra payment field to see how paying more can save you thousands
      and cut years off your loan. Supports monthly, bi-weekly, and weekly frequencies.
    </p>
    <p>All calculations run locally in your browser.</p>
  </div>
</ToolLayout>

<script>
  function calculateLoan() {
    const amount = parseFloat(document.getElementById('loan-amount')?.value);
    const annualRate = parseFloat(document.getElementById('interest-rate')?.value);
    const years = parseFloat(document.getElementById('loan-term')?.value);
    const freq = parseInt(document.getElementById('payment-frequency')?.value) || 12;
    const extraPayment = parseFloat(document.getElementById('extra-payment')?.value) || 0;

    if (!amount || amount <= 0) { showToast('Please enter a valid loan amount.', 'error'); return; }
    if (isNaN(annualRate)) { showToast('Please enter a valid interest rate.', 'error'); return; }
    if (!years || years <= 0) { showToast('Please enter a valid loan term.', 'error'); return; }

    const totalPeriods = years * freq;
    const periodRate = (annualRate / 100) / freq;

    let payment;
    if (periodRate === 0) {
      payment = amount / totalPeriods;
    } else {
      payment = amount * (periodRate * Math.pow(1 + periodRate, totalPeriods)) / (Math.pow(1 + periodRate, totalPeriods) - 1);
    }

    const totalPaid = payment * totalPeriods;
    const totalInterest = totalPaid - amount;

    // Extra payment calculation
    let payoffPeriods = totalPeriods;
    let interestWithExtra = totalInterest;
    if (extraPayment > 0) {
      let balance = amount;
      payoffPeriods = 0;
      let totalInterestPaid = 0;
      while (balance > 0 && payoffPeriods < totalPeriods * 2) {
        const interestForPeriod = balance * periodRate;
        totalInterestPaid += interestForPeriod;
        let principalPayment = payment - interestForPeriod + extraPayment;
        if (principalPayment > balance) principalPayment = balance;
        balance -= principalPayment;
        payoffPeriods++;
      }
      interestWithExtra = totalInterestPaid;
    }

    const freqLabel = freq === 12 ? 'monthly' : freq === 26 ? 'bi-weekly' : 'weekly';

    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');
    document.getElementById('monthly-payment').textContent = '💰' + payment.toFixed(2);
    document.getElementById('payment-label').textContent = freqLabel + ' payment';
    document.getElementById('total-payments').textContent = totalPeriods;
    document.getElementById('total-interest').textContent = '💰' + totalInterest.toFixed(2);
    document.getElementById('total-cost').textContent = '💰' + totalPaid.toFixed(2);

    const principalPct = (amount / totalPaid * 100).toFixed(1);
    const interestPct = (totalInterest / totalPaid * 100).toFixed(1);
    document.getElementById('principal-bar').style.width = principalPct + '%';
    document.getElementById('interest-bar').style.width = interestPct + '%';
    document.getElementById('principal-pct').textContent = principalPct + '%';
    document.getElementById('interest-pct').textContent = interestPct + '%';

    if (extraPayment > 0) {
      const yearsSaved = (totalPeriods - payoffPeriods) / freq;
      document.getElementById('extra-comparison').classList.remove('hidden');
      document.getElementById('extra-payoff-time').textContent = payoffPeriods + ' periods (' + yearsSaved.toFixed(1) + ' years saved)';
      document.getElementById('interest-saved').textContent = '💰' + Math.max(0, totalInterest - interestWithExtra).toFixed(2);
    } else {
      document.getElementById('extra-comparison').classList.add('hidden');
    }
  }

  document.getElementById('calc-loan')?.addEventListener('click', calculateLoan);
</script>
