---
import ToolLayout from '../../layouts/ToolLayout.astro';
import TextareaInput from '../../components/ui/TextareaInput.astro';
import ResultDisplay from '../../components/tool/ResultDisplay.astro';

const pageTitle = 'JWT Decoder – Decode JSON Web Tokens Online | MetisTools';
const pageDescription = 'Decode JWT tokens and inspect header, payload, and signature. Expiry countdown, claim explanations, and field copying. Free online JWT decoder.';

// 标准 JWT Claim 说明
const CLAIM_DESCRIPTIONS = {
  iss: 'Issuer — who issued the token',
  sub: 'Subject — who the token is about',
  aud: 'Audience — who the token is intended for',
  exp: 'Expiration Time — when the token expires',
  nbf: 'Not Before — when the token becomes valid',
  iat: 'Issued At — when the token was created',
  jti: 'JWT ID — unique identifier for the token',
};
---

<ToolLayout title={pageTitle} description={pageDescription} toolHref="/tools/jwt-decoder">
  <div slot="input">
    <div class="space-y-4">
      <TextareaInput id="jwt-input" label="JWT Token" placeholder="Paste your JWT token here...&#10;eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." rows={4} monospace={true} required={true} />

      <button type="button" id="btn-decode" class="tool-btn-primary w-full">
        Decode JWT
      </button>
    </div>
  </div>

  <div slot="result">
    <ResultDisplay emptyMessage="Paste a JWT token and click <strong>Decode JWT</strong> to inspect its contents." onCopy={true}>
      <div slot="result-content" class="space-y-4">
        <!-- 过期状态 -->
        <div id="jwt-expiry-banner" class="hidden rounded-lg p-3 text-sm font-medium"></div>

        <div id="jwt-output">
        </div>
      </div>
    </ResultDisplay>
  </div>

  <div slot="description">
    <p>
      JWT (JSON Web Token) is a compact, URL-safe means of representing claims between two parties. It's widely used for authentication, authorization, and information exchange in web applications and APIs. This tool lets you decode and inspect JWT tokens directly in your browser.
    </p>
    <p>
      <strong>How It Works:</strong> A JWT consists of three Base64Url-encoded parts separated by dots: <code>header.payload.signature</code>. The header describes the token type and signing algorithm. The payload contains the claims (data). The signature verifies the token hasn't been tampered with.
    </p>
    <p>
      <strong>Token Expiry:</strong> If the token contains an <code>exp</code> (expiration) claim, the tool shows a countdown or a red warning if the token has expired. Standard claims like <code>iat</code>, <code>sub</code>, <code>iss</code> are explained inline.
    </p>
    <p>
      <strong>Privacy & Security:</strong> All decoding happens entirely in your browser using JavaScript. Your JWT tokens are never sent to any server, logged, or stored. However, never paste real production tokens on untrusted or shared computers — the decoded data may contain sensitive user information.
    </p>
    <p>
      <strong>Common Uses:</strong> JWTs are used by OAuth 2.0, OpenID Connect, Firebase Auth, Auth0, and countless custom authentication systems. Developers use this decoder to debug token payloads, verify claim values, and check token expiration during development and testing.
    </p>
  </div>
</ToolLayout>

<script>
  let currentDecoded = '';

  function base64UrlDecode(str) {
    str = str.replace(/-/g, '+').replace(/_/g, '/');
    while (str.length % 4) str += '=';
    try {
      return JSON.parse(atob(str));
    } catch {
      return null;
    }
  }

  function formatJSON(obj) {
    try {
      return JSON.stringify(obj, null, 2);
    } catch {
      return String(obj);
    }
  }

  function formatTimestamp(ts) {
    const date = new Date(ts * 1000);
    return date.toISOString().replace('T', ' ').replace('Z', '') + ' UTC';
  }

  function timeRemaining(expTs) {
    const now = Math.floor(Date.now() / 1000);
    const diff = expTs - now;
    if (diff <= 0) return { expired: true, text: 'Expired' };
    const days = Math.floor(diff / 86400);
    const hours = Math.floor((diff % 86400) / 3600);
    const mins = Math.floor((diff % 3600) / 60);
    if (days > 0) return { expired: false, text: `Expires in ${days}d ${hours}h ${mins}m` };
    if (hours > 0) return { expired: false, text: `Expires in ${hours}h ${mins}m` };
    return { expired: false, text: `Expires in ${mins}m` };
  }

  function decodeJWT() {
    const input = document.getElementById('jwt-input')?.value?.trim();
    if (!input) { showToast('Please paste a JWT token.', 'error'); return; }

    const parts = input.split('.');
    if (parts.length !== 3) {
      showToast('Invalid JWT format. A JWT must have 3 parts separated by dots.', 'error');
      return;
    }

    const header = base64UrlDecode(parts[0]);
    const payload = base64UrlDecode(parts[1]);

    if (!header) {
      document.getElementById('result-empty').classList.add('hidden');
      document.getElementById('result-data').classList.remove('hidden');
      document.getElementById('jwt-output').innerHTML = '<div class="text-red-600 text-sm">Invalid Header: could not decode Base64Url.</div>';
      return;
    }

    if (!payload) {
      document.getElementById('result-empty').classList.add('hidden');
      document.getElementById('result-data').classList.remove('hidden');
      document.getElementById('jwt-output').innerHTML = '<div class="text-red-600 text-sm">Invalid Payload: could not decode Base64Url.</div>';
      return;
    }

    // Build output
    let html = '';

    // Header section
    html += '<div class="mb-4"><div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Header</div>';
    html += `<pre class="bg-gray-50 rounded-lg p-3 border border-gray-200 font-mono text-xs text-gray-800 whitespace-pre-wrap">${escapeHtml(formatJSON(header))}</pre></div>`;

    // Payload section
    html += '<div class="mb-4"><div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Payload</div>';

    // 先显示完整 payload
    html += `<pre class="bg-gray-50 rounded-lg p-3 border border-gray-200 font-mono text-xs text-gray-800 whitespace-pre-wrap max-h-[300px] overflow-y-auto">${escapeHtml(formatJSON(payload))}</pre>`;

    // 标准 claim 说明
    const claimNotes = [];
    for (const key of Object.keys(CLAIM_DESCRIPTIONS)) {
      if (payload[key] !== undefined) {
        let val = payload[key];
        if (key === 'exp' || key === 'iat' || key === 'nbf') {
          val = formatTimestamp(val);
        }
        claimNotes.push(`<div class="flex justify-between py-1 text-xs"><span class="text-gray-500"><code class="text-primary-600">${key}</code> — ${CLAIM_DESCRIPTIONS[key]}</span><span class="font-mono text-gray-800">${val}</span></div>`);
      }
    }
    if (claimNotes.length > 0) {
      html += '<div class="mt-3 space-y-0.5">' + claimNotes.join('') + '</div>';
    }

    html += '</div>';

    // Signature section
    html += '<div class="mb-4"><div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Signature</div>';
    html += `<div class="font-mono text-[10px] text-gray-400 break-all bg-gray-50 rounded-lg p-3 border border-gray-200">${escapeHtml(parts[2])}</div></div>`;

    // Expiry banner
    const expiryBanner = document.getElementById('jwt-expiry-banner');
    if (payload.exp) {
      const { expired, text } = timeRemaining(payload.exp);
      expiryBanner.classList.remove('hidden');
      if (expired) {
        expiryBanner.className = 'rounded-lg p-3 text-sm bg-red-50 border border-red-200 text-red-700';
        expiryBanner.textContent = '⚠ ' + text + ' at ' + formatTimestamp(payload.exp);
      } else {
        expiryBanner.className = 'rounded-lg p-3 text-sm bg-green-50 border border-green-200 text-green-700';
        expiryBanner.textContent = '✓ ' + text + ' (' + formatTimestamp(payload.exp) + ')';
      }
    } else {
      expiryBanner.classList.add('hidden');
    }

    document.getElementById('result-empty').classList.add('hidden');
    document.getElementById('result-data').classList.remove('hidden');
    document.getElementById('jwt-output').innerHTML = html;

    // 构建可复制文本
    currentDecoded = '=== Header ===\n' + formatJSON(header) + '\n\n=== Payload ===\n' + formatJSON(payload) + '\n\n=== Signature ===\n' + parts[2];
  }

  function escapeHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  document.getElementById('btn-decode')?.addEventListener('click', decodeJWT);

  document.getElementById('btn-copy-result')?.addEventListener('click', () => {
    if (!currentDecoded) return;
    navigator.clipboard.writeText(currentDecoded).then(() => {
      showToast('Decoded JWT copied!', 'success');
    }).catch(() => showToast('Failed to copy.', 'error'));
  });
</script>
