---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "UUID / GUID Generator - Random UUID v4";
const description = "Generate random UUID v4 (or custom number of UUIDs). Free online tool.";
---

<BaseLayout title={title} description={description} currentPath="/tools/uuid-generator">
  <div class="max-w-2xl mx-auto py-8">
    <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-100">
      <h1 class="text-3xl font-bold mb-2">🆔 UUID / GUID Generator</h1>
      <p class="text-gray-600 mb-6">Generate random UUID v4 (universally unique identifier).</p>

      <div class="flex items-center gap-2 mb-4">
        <label class="text-sm font-medium">Number of UUIDs:</label>
        <input type="number" id="count" min="1" max="100" value="1" class="w-20 px-2 py-1 rounded border border-gray-300 text-center">
        <button id="generate-btn" class="bg-indigo-600 text-white px-4 py-2 rounded-full text-sm">Generate</button>
      </div>

      <textarea id="output" rows="6" class="w-full px-4 py-3 rounded-xl border border-gray-300 font-mono text-sm" readonly placeholder="UUIDs will appear here..."></textarea>
      <button id="copy-btn" class="mt-2 bg-gray-200 hover:bg-gray-300 px-4 py-2 rounded-full text-sm">Copy All</button>
    </div>
  </div>

  <script>
    const countInput = document.getElementById('count');
    const generateBtn = document.getElementById('generate-btn');
    const output = document.getElementById('output');
    const copyBtn = document.getElementById('copy-btn');

    function generateUUID() {
      return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
        const r = (Math.random() * 16) | 0;
        const v = c === 'x' ? r : (r & 0x3) | 0x8;
        return v.toString(16);
      });
    }

    function showMsg(msg, type) {
      if (typeof showMessage === 'function') showMessage(msg, type);
      else alert(msg);
    }

    generateBtn.addEventListener('click', () => {
      let count = parseInt(countInput.value);
      if (isNaN(count) || count < 1) count = 1;
      if (count > 100) count = 100;
      const uuids = [];
      for (let i = 0; i < count; i++) {
        uuids.push(generateUUID());
      }
      output.value = uuids.join('\n');
      showMsg(`Generated ${uuids.length} UUID(s)`, 'success');
    });

    copyBtn.addEventListener('click', () => {
      if (output.value) {
        navigator.clipboard.writeText(output.value).then(() => showMsg('Copied!', 'success')).catch(() => showMsg('Copy failed', 'error'));
      } else {
        showMsg('Nothing to copy', 'error');
      }
    });
  </script>
  <Schema
    toolName="UUID Generator"
    description={description}
    url={Astro.url.href}
  />
</BaseLayout>