---
import Schema from '../../components/Schema.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Image Format Converter - PNG, JPEG, WebP";
const description = "Convert images between PNG, JPEG, and WebP formats. Adjust quality for JPEG/WebP.";
---

<BaseLayout title={title} description={description} currentPath="/tools/image-format-converter">
  <div class="max-w-2xl mx-auto py-8">
    <div class="bg-white dark:bg-slate-950 rounded-2xl shadow-md p-6 border border-gray-100 dark:border-slate-800">
      <h1 class="text-3xl font-bold mb-2">🔄 Image Format Converter</h1>
      <p class="text-gray-600 dark:text-gray-300 mb-6">Convert between PNG, JPEG, and WebP formats. All processing is local.</p>

      <div id="upload-zone" class="border-2 border-dashed border-gray-300 dark:border-slate-700 rounded-xl p-6 text-center cursor-pointer hover:border-indigo-500 transition">
        <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
        </svg>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">Drag & drop an image here, or <span class="text-indigo-600 dark:text-indigo-400 font-medium">browse</span></p>
        <p class="text-xs text-gray-400 mt-1">Supports PNG, JPEG, WebP</p>
        <input type="file" id="file-input" accept="image/png,image/jpeg,image/webp" class="hidden text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950">
      </div>

      <div class="mt-4 grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Convert to</label>
          <select id="target-format" class="w-full px-4 py-2 rounded-full border border-gray-300 dark:border-slate-700 text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950">
            <option value="image/png">PNG</option>
            <option value="image/jpeg">JPEG</option>
            <option value="image/webp">WebP</option>
          </select>
        </div>
        <div id="quality-container" class="hidden">
          <label class="block text-sm font-medium mb-1">Quality: <span id="quality-value">90</span>%</label>
          <input type="range" id="quality" min="1" max="100" value="90" class="w-full text-gray-900 dark:text-gray-100 bg-white dark:bg-slate-950">
        </div>
      </div>

      <button id="convert-btn" class="w-full bg-indigo-600 dark:bg-indigo-500 text-white py-2 rounded-full mt-4 disabled:opacity-50" disabled>Convert</button>

      <div id="result-area" class="mt-6 hidden">
        <p class="font-semibold text-green-600">✓ Conversion completed</p>
        <div class="flex gap-4 mt-2">
          <img id="preview" class="max-h-48 rounded border" />
          <button id="download-btn" class="bg-indigo-600 dark:bg-indigo-500 text-white px-4 py-2 rounded-full text-sm self-end">Download</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const uploadZone = document.getElementById('upload-zone');
    const fileInput = document.getElementById('file-input');
    const targetFormat = document.getElementById('target-format');
    const qualityContainer = document.getElementById('quality-container');
    const qualitySlider = document.getElementById('quality');
    const qualityValue = document.getElementById('quality-value');
    const convertBtn = document.getElementById('convert-btn');
    const resultArea = document.getElementById('result-area');
    const previewImg = document.getElementById('preview');
    const downloadBtn = document.getElementById('download-btn');
    let currentFile = null;
    let currentResultBlob = null;
    let currentResultType = null;

    function showMsg(msg, type) {
      if (typeof showMessage === 'function') showMessage(msg, type);
      else alert(msg);
    }

    function updateQualityVisibility() {
      const format = targetFormat.value;
      if (format === 'image/jpeg' || format === 'image/webp') {
        qualityContainer.classList.remove('hidden');
      } else {
        qualityContainer.classList.add('hidden');
      }
    }

    targetFormat.addEventListener('change', updateQualityVisibility);
    qualitySlider.addEventListener('input', () => {
      qualityValue.textContent = qualitySlider.value;
    });

    async function handleFile(file) {
      if (!file || !file.type.startsWith('image/')) {
        showMsg('Please upload an image file.', 'error');
        return;
      }
      currentFile = file;
      convertBtn.disabled = false;
      // 可选：显示原始图片预览
    }

    async function convert() {
      if (!currentFile) return;
      const format = targetFormat.value;
      const quality = qualitySlider.value / 100;
      convertBtn.disabled = true;
      try {
        const img = await createImageBitmap(currentFile);
        const canvas = document.createElement('canvas');
        canvas.width = img.width;
        canvas.height = img.height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0);
        const blob = await new Promise(resolve => canvas.toBlob(resolve, format, quality));
        currentResultBlob = blob;
        currentResultType = format;
        const url = URL.createObjectURL(blob);
        previewImg.src = url;
        resultArea.classList.remove('hidden');
        showMsg('Conversion successful', 'success');
      } catch (err) {
        showMsg('Conversion failed: ' + err.message, 'error');
      } finally {
        convertBtn.disabled = false;
      }
    }

    uploadZone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', (e) => {
      if (e.target.files.length) handleFile(e.target.files[0]);
    });
    uploadZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadZone.classList.add('border-indigo-500', 'bg-indigo-50');
    });
    uploadZone.addEventListener('dragleave', () => {
      uploadZone.classList.remove('border-indigo-500', 'bg-indigo-50');
    });
    uploadZone.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('border-indigo-500', 'bg-indigo-50');
      const file = e.dataTransfer.files[0];
      if (file && file.type.startsWith('image/')) handleFile(file);
      else showMsg('Please drop an image file.', 'error');
    });
    convertBtn.addEventListener('click', convert);
    downloadBtn.addEventListener('click', () => {
      if (currentResultBlob) {
        const url = URL.createObjectURL(currentResultBlob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `converted.${currentResultType.split('/')[1]}`;
        a.click();
        URL.revokeObjectURL(url);
      } else {
        showMsg('No conversion result', 'error');
      }
    });
    updateQualityVisibility();
  </script>
  <Schema
    toolName="Image Format Converter"
    description={description}
    url={Astro.url.href}
  />
</BaseLayout>