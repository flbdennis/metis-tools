---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCard from "../components/ToolCard.astro";
import { allTools } from "../data/tools";

const title = "MetisTools - Free Online Converters & Calculators";
const description =
  "All-in-one toolkit: file conversion, unit conversion, health, finance, and daily math tools. 100% free, no signup required.";
const toolCount = allTools.length;
const siteUrl = Astro.site.href;
---

<BaseLayout title={title} description={description} currentPath="/">
  <style is:global>
    /* 动画层1 - 大范围快速浮动 */
    .hero-bg-animation {
      position: absolute;
      top: -40%;
      left: -30%;
      width: 200%;
      height: 200%;
      background: radial-gradient(
        circle at 30% 40%,
        rgba(79, 70, 229, 0.6) 0%,
        rgba(6, 182, 212, 0.5) 30%,
        rgba(236, 72, 153, 0.3) 60%,
        transparent 85%
      );
      border-radius: 50%;
      filter: blur(100px);
      animation: dramaticFloat 4s ease-in-out infinite alternate;
      will-change: transform;
      pointer-events: none;
      z-index: 0;
    }
    /* 动画层2 - 相反方向 */
    .hero-bg-animation-2 {
      position: absolute;
      bottom: -30%;
      right: -25%;
      width: 180%;
      height: 180%;
      background: radial-gradient(
        circle at 70% 60%,
        rgba(139, 92, 246, 0.55) 0%,
        rgba(59, 130, 246, 0.45) 40%,
        transparent 70%
      );
      border-radius: 60%;
      filter: blur(90px);
      animation: dramaticFloatReverse 5s ease-in-out infinite alternate;
      will-change: transform;
      pointer-events: none;
      z-index: 0;
    }
    /* 动画层3 - 第三层，增加丰富度 */
    .hero-bg-animation-3 {
      position: absolute;
      top: 10%;
      left: 20%;
      width: 150%;
      height: 150%;
      background: radial-gradient(
        circle at 50% 50%,
        rgba(245, 158, 11, 0.3) 0%,
        rgba(16, 185, 129, 0.25) 50%,
        transparent 80%
      );
      border-radius: 50%;
      filter: blur(120px);
      animation: slowWobble 6s ease-in-out infinite alternate;
      will-change: transform;
      pointer-events: none;
      z-index: 0;
    }

    @keyframes dramaticFloat {
      0% {
        transform: translate(0%, 0%) scale(1);
        opacity: 0.6;
      }
      100% {
        transform: translate(20%, 20%) scale(1.6);
        opacity: 1;
      }
    }
    @keyframes dramaticFloatReverse {
      0% {
        transform: translate(0%, 0%) scale(1);
        opacity: 0.4;
      }
      100% {
        transform: translate(-18%, -18%) scale(1.5);
        opacity: 0.9;
      }
    }
    @keyframes slowWobble {
      0% {
        transform: rotate(0deg) scale(1);
        opacity: 0.3;
      }
      100% {
        transform: rotate(5deg) scale(1.4);
        opacity: 0.9;
      }
    }

    /* 深色模式增强 */
    html.dark .hero-bg-animation {
      background: radial-gradient(
        circle at 30% 40%,
        rgba(129, 140, 248, 0.7) 0%,
        rgba(34, 211, 238, 0.6) 30%,
        rgba(244, 114, 182, 0.4) 60%,
        transparent 85%
      );
    }
    html.dark .hero-bg-animation-2 {
      background: radial-gradient(
        circle at 70% 60%,
        rgba(167, 139, 250, 0.65) 0%,
        rgba(96, 165, 250, 0.55) 40%,
        transparent 70%
      );
    }
    html.dark .hero-bg-animation-3 {
      background: radial-gradient(
        circle at 50% 50%,
        rgba(245, 158, 11, 0.4) 0%,
        rgba(16, 185, 129, 0.35) 50%,
        transparent 80%
      );
    }
    .hero-bg-animation,
    .hero-bg-animation-2,
    .hero-bg-animation-3 {
      transform: translateZ(0);
      backface-visibility: hidden;
    }
  </style>

  <!-- Hero 区域（Logo + 标题 + 描述） -->
  <section
    class="relative text-center pt-8 pb-4 md:pt-12 md:pb-6 overflow-hidden -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8"
    id="hero-section"
  >
    <div class="hero-bg-animation"></div>
    <div class="hero-bg-animation-2"></div>
    <div class="hero-bg-animation-3"></div>
    <div class="relative z-10">
      <!-- Logo 放大 -->
      <img
        src="/logo.webp"
        alt="MetisTools Logo"
        class="mx-auto mb-6 h-24 md:h-32 w-auto"
      />

      <h1
        class="text-4xl md:text-6xl font-bold bg-gradient-to-r from-indigo-600 to-cyan-500 bg-clip-text text-transparent mt-4"
      >
        Convert Anything in Seconds
      </h1>
      <p
        class="mt-4 text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto"
      >
        Free online file converters, unit converters, health and finance
        calculators — everything you need.
      </p>
    </div>
  </section>

  <!-- 所有工具网格（标题 + 搜索框） -->
  <section class="py-8">
    <div
      class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6"
    >
      <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
        All Tools
      </h2>
      <div class="w-full sm:w-auto" id="search-container">
        <input
          type="text"
          placeholder={`Search ${toolCount} tools...`}
          class="w-full sm:w-80 px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
          id="searchInput"
        />
      </div>
    </div>
    <div
      class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4 md:gap-6"
      id="toolsGrid"
    >
      {allTools.map((tool) => <ToolCard {...tool} />)}
    </div>
  </section>

  <script>
    // 仅保留搜索过滤逻辑（删除所有浮动搜索框相关代码）
    const searchInput = document.getElementById("searchInput");
    const toolsGrid = document.getElementById("toolsGrid");
    if (searchInput && toolsGrid) {
      searchInput.addEventListener("input", (e) => {
        const term = e.target.value.toLowerCase().trim();
        const cards = toolsGrid.querySelectorAll("a");
        cards.forEach((card) => {
          const title = card.querySelector("h3")?.innerText.toLowerCase() || "";
          const desc = card.querySelector("p")?.innerText.toLowerCase() || "";
          if (term === "" || title.includes(term) || desc.includes(term)) {
            card.style.display = "";
          } else {
            card.style.display = "none";
          }
        });
      });
    }
  </script>

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      url: siteUrl,
      name: "MetisTools",
      description: "Free online converters, calculators, developer tools",
      potentialAction: {
        "@type": "SearchAction",
        target: siteUrl + "?q={search_term_string}",
        "query-input": "required name=search_term_string",
      },
    })}
  />
</BaseLayout>
