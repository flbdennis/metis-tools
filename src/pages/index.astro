---
// 首页 —— 精选工具 + 分类导航 + 博客推荐
import BaseLayout from '../layouts/BaseLayout.astro';
import AdPlaceholder from '../components/ui/AdPlaceholder.astro';
import ToolIcon from '../components/ui/ToolIcon.astro';
import { navigationConfig } from '../data/navigation';
import { siteConfig } from '../data/site';
import { allTools, getFeaturedTools, getCategories } from '../data/tools';

const pageTitle = `${siteConfig.name} — Free Online Converters & Calculators`;
const pageDescription = siteConfig.description;

const featuredTools = getFeaturedTools();
const categories = getCategories();
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  currentPath="/"
>
  <!-- ===== Hero Section ===== -->
  <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary-600 via-primary-700 to-indigo-900 px-6 py-16 sm:py-20 text-center text-white mb-12">
    <div class="relative z-10 max-w-2xl mx-auto">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
        {siteConfig.tagline}
      </h1>
      <p class="mt-4 text-lg text-primary-100 leading-relaxed">
        {pageDescription}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3">
        <a href="#all-tools" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-white text-primary-700 font-semibold hover:bg-gray-100 transition-colors shadow-md">
          Explore All Tools
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </a>
        <a href="/blog" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-primary-500/30 text-white font-semibold hover:bg-primary-500/40 transition-colors border border-primary-400/30">
          Read Our Blog
        </a>
      </div>
    </div>
    <!-- 背景装饰 -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.1),transparent_70%)]" aria-hidden="true"></div>
  </section>

  <!-- [AdSense 广告位]: Hero 下方横幅 -->
  <div class="mb-12">
    <AdPlaceholder position="hero-banner" />
  </div>

  <!-- ===== 精选工具区（按市场需求排序的 6 个工具） ===== -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-900">Popular Tools</h2>
      <span class="text-xs text-gray-400">Most used by our visitors</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {featuredTools.map((tool, index) => (
        <a href={tool.href} class="tool-card group flex items-start gap-4">
          <!-- 热度排名角标 -->
          <span class="shrink-0 flex items-center justify-center w-10 h-10 rounded-lg bg-primary-50 text-primary-600 text-sm font-bold group-hover:bg-primary-100 transition-colors">
            {index + 1}
          </span>
          <div class="min-w-0">
            <h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition-colors truncate">
              {tool.title}
            </h3>
            <p class="mt-0.5 text-xs text-gray-500 line-clamp-2">{tool.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== 分类区 ===== -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Browse by Category</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {categories.map(cat => (
        <a href={`/${cat.key === 'calculators' ? 'calculators' : cat.key === 'converters' ? 'converters' : cat.key === 'dev' ? 'dev-tools' : cat.key === 'image' ? 'image-tools' : 'text-tools'}`} class="tool-card text-center py-6">
          <h3 class="font-semibold text-gray-900">{cat.name}</h3>
          <p class="mt-1 text-xs text-gray-500">{cat.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- [AdSense 广告位]: 工具列表中间 -->
  <div class="mb-12">
    <AdPlaceholder position="content-middle" />
  </div>

  <!-- ===== 全部工具区 ===== -->
  <section id="all-tools" class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">All Tools</h2>

    {Object.entries(navigationConfig.categoryMap).map(([catKey, catInfo]) => {
      const catTools = allTools.filter(t => t.category === catKey);

      return (
        <div class="mb-8">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-lg font-semibold text-gray-800">{catInfo.name}</h3>
            <a href={catInfo.href} class="text-sm text-primary-600 hover:text-primary-700 font-medium">View all →</a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {catTools.map(tool => (
              <a href={tool.href} class="flex items-center gap-3 rounded-lg border border-gray-300 bg-white p-3.5 hover:border-primary-400 hover:shadow-sm transition-all">
                <span class="shrink-0 text-primary-500">
                  <ToolIcon name={tool.icon} class="h-4 w-4" />
                </span>
                <span class="text-sm font-medium text-gray-800 truncate">{tool.title}</span>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </section>

  <!-- ===== 博客区（预留） ===== -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest from Our Blog</h2>
    <p class="text-sm text-gray-500">Tips, guides, and tutorials to help you get the most out of our tools.</p>
    <div class="mt-4">
      <a href="/blog" class="text-sm font-medium text-primary-600 hover:text-primary-700">Browse all articles →</a>
    </div>
  </section>

  <!-- [AdSense 广告位]: Footer 上方 -->
  <div class="mb-12">
    <AdPlaceholder position="footer-banner" />
  </div>
</BaseLayout>
