---
// 根布局 —— 所有页面的基础包裹器
import SeoHead from '../components/seo/SeoHead.astro';
import Schema from '../components/seo/Schema.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import CookieConsent from '../components/ui/CookieConsent.astro';
import Toast from '../components/ui/Toast.astro';
import SocialShare from '../components/seo/SocialShare.astro';
import { siteConfig } from '../data/site';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noIndex?: boolean;
  currentPath?: string;
  showBreadcrumb?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  noIndex = false,
  currentPath = '/',
  showBreadcrumb = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noIndex={noIndex}
    />
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased min-h-screen flex flex-col">
    <!-- 网站结构化数据 -->
    <Schema type="WebSite" />

    <!-- 顶部导航 -->
    <Header currentPath={currentPath} />

    <!-- 主内容 -->
    <main class="flex-1">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-4">
        {showBreadcrumb && <Breadcrumb path={currentPath} />}
        <slot />
      </div>
    </main>

    <!-- 页脚 -->
    <Footer />

    <!-- 浮动社交分享栏 -->
    <SocialShare />

    <!-- Cookie 同意弹窗 -->
    <CookieConsent />

    <!-- Toast 通知容器 -->
    <Toast />

    <!-- ===== 第三方脚本（受 Cookie 同意控制） ===== -->
    <script define:vars={{ gaId: siteConfig.googleAnalyticsId }}>
      // Cookie 同意管理
      (function () {
        const STORAGE_KEY = 'cookie-preferences';
        const preferences = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');

        // 默认：未选择时所有功能关闭
        const consent = preferences || {
          necessary: true,   // 必要 Cookie 始终开启
          analytics: false,
          advertising: false,
        };

        // Google Analytics（仅 analytics 同意时加载）
        if (consent.analytics) {
          window.addEventListener('load', () => {
            setTimeout(() => {
              const script = document.createElement('script');
              script.src = `https://www.googletagmanager.com/gtag/js?id=${gaId}`;
              script.async = true;
              document.head.appendChild(script);
              window.dataLayer = window.dataLayer || [];
              function gtag() { dataLayer.push(arguments); }
              gtag('js', new Date());
              gtag('config', gaId);
            }, 3000);
          });
        }
      })();
    </script>
  </body>
</html>
