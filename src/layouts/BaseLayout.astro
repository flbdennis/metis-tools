---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { allTools } from "../data/tools";

const { title, description, currentPath = "/" } = Astro.props;
const siteUrl = Astro.site.href;

// 工具分类映射表
const categoryMap = {
  calculators: "/calculators",
  converters: "/converters",
  dev: "/dev-tools",
  image: "/image-tools",
  text: "/text-tools",
};

// 构建工具 slug -> 分类URL的映射
const toolCategoryMap = new Map();
for (const tool of allTools) {
  const slug = tool.href.replace("/tools/", "");
  if (slug && categoryMap[tool.category]) {
    toolCategoryMap.set(slug, categoryMap[tool.category]);
  }
}

// 生成面包屑项
function generateBreadcrumbs(path) {
  const segments = path.split("/").filter(Boolean);
  const items = [{ name: "Home", url: "/" }];
  let accumulated = "";

  for (let i = 0; i < segments.length; i++) {
    const seg = segments[i];
    accumulated += `/${seg}`;
    if (seg === "support") continue; // 跳过 support 层级

    let name = seg.charAt(0).toUpperCase() + seg.slice(1).replace(/-/g, " ");
    let url = accumulated;

    if (seg === "tools") {
      name = "Tools";
      const nextSeg = segments[i + 1];
      url = nextSeg
        ? toolCategoryMap.get(nextSeg) || "/calculators"
        : "/calculators";
    } else if (seg === "blog") {
      name = "Blog";
    }
    items.push({ name, url });
  }
  if (items.length > 1) items[items.length - 1].url = null;
  return items;
}

const breadcrumbItems = generateBreadcrumbs(currentPath);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(currentPath, siteUrl).href} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL("/og-default.jpg", siteUrl).href}
    />
    <meta property="og:url" content={new URL(currentPath, siteUrl).href} />
    <meta property="og:site_name" content="MetisTools" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={new URL("/og-default.jpg", siteUrl).href}
    />

    <!-- 预连接 Google 服务 -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body
    class="bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800 text-gray-900 dark:text-gray-100 font-sans min-h-screen flex flex-col"
  >
    <Navigation currentPath={currentPath} />
    <main class="flex-1 pt-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        {breadcrumbItems.length > 1 && <Breadcrumbs items={breadcrumbItems} />}
        <slot />
      </div>
    </main>
    <Footer />
    <script defer src="/js/common.js"></script>

    <!-- Google Analytics 延迟加载 -->
    <script>
      (function () {
        window.addEventListener("load", () => {
          setTimeout(() => {
            const script = document.createElement("script");
            script.src =
              "https://www.googletagmanager.com/gtag/js?id=G-87VGYW1H47";
            script.async = true;
            document.head.appendChild(script);
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-87VGYW1H47");
          }, 3000);
        });
      })();
    </script>
  </body>
</html>


<body>
  <Navigation currentPath={currentPath} />
  <main class="flex-1 pt-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      {breadcrumbItems.length > 1 && <Breadcrumbs items={breadcrumbItems} />}
      <slot />
    </div>
  </main>
  <Footer />
</body>